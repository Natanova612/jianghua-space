  const glowClasses = {
    blue: 'bg-aurora-blue/60 shadow-[0_0_60px_-12px_rgba(56,189,248,0.25)]',
    green: 'bg-aurora-green/60 shadow-[0_0_60px_-12px_rgba(74,222,128,0.25)]',
    gold: 'bg-resonance-gold/60 shadow-[0_0_60px_-12px_rgba(251,191,36,0.25)]',
    purple: 'bg-purple-400/60 shadow-[0_0_60px_-12px_rgba(192,132,252,0.25)]',
  };

  function openModal(file) {
    const modal = document.getElementById('core-modal');
    const window = document.getElementById('core-modal-window');
    const accent = document.getElementById('modal-accent');
    
    document.getElementById('modal-label').textContent = file.label;
    document.getElementById('modal-title').textContent = file.title;
    document.getElementById('modal-meta').textContent = `~/starfield/core/${file.label.toLowerCase()}.md · ${file.content.length} bytes`;
    document.getElementById('modal-content').textContent = file.content;
    document.getElementById('modal-filesize').textContent = `${file.content.length} chars`;
    
    // Generate line numbers
    const lines = file.content.split('\n').length;
    const lineNumbers = Array.from({length: lines + 4}, (_, i) => i + 1).join('\n');
    document.getElementById('modal-linenumbers').textContent = lineNumbers;
    
    // Set accent color
    accent.className = `h-[2px] w-full ${glowClasses[file.color] || glowClasses.blue}`;
    
    // Show modal
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    
    // Animate in
    requestAnimationFrame(() => {
      window.classList.remove('opacity-0', 'scale-[0.96]', 'translate-y-2');
      window.classList.add('opacity-100', 'scale-100', 'translate-y-0');
    });
  }

  function closeModal() {
    const modal = document.getElementById('core-modal');
    const window = document.getElementById('core-modal-window');
    
    window.classList.remove('opacity-100', 'scale-100', 'translate-y-0');
    window.classList.add('opacity-0', 'scale-[0.96]', 'translate-y-2');
    
    setTimeout(() => {
      modal.classList.add('hidden');
      document.body.style.overflow = '';
    }, 350);
  }

  document.querySelectorAll('[data-core-file]').forEach(card => {
    card.addEventListener('click', () => {
      const id = card.getAttribute('data-core-file');
      const file = coreFiles.find(f => f.id === id);
      if (!file) return;
      openModal(file);
    });
  });

  document.querySelectorAll('[data-close-modal]').forEach(el => {
    el.addEventListener('click', closeModal);
  });

  document.getElementById('core-modal').addEventListener('click', (e) => {
    if (e.target.id === 'core-modal' || e.target.hasAttribute('data-close-modal')) {
      closeModal();
    }
  });

  // ESC to close
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !document.getElementById('core-modal').classList.contains('hidden')) {
      closeModal();
    }
  });
</script>
