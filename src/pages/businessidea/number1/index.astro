      <span class="w-2 h-2 rounded-full bg-slate-600 group-hover:bg-warm-amber transition-colors"></span>
    </a>
  </div>

  {/* Back to Top */}
  <button id="back-to-top" class="fixed bottom-8 right-8 z-40 w-10 h-10 rounded-full glass flex items-center justify-center text-slate-400 hover:text-warm-amber hover:border-warm-amber/30 transition-all duration-300 opacity-0 translate-y-4 pointer-events-none">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>
  </button>

  {/* Active nav highlight on scroll */}
  <script>
    const sections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('.nav-link');
    const sideNavDots = document.querySelectorAll('.side-nav-dot');
    const sideNav = document.getElementById('side-nav');
    const backToTop = document.getElementById('back-to-top');
    
    function updateActiveNav() {
      let current = '';
      sections.forEach(section => {
        const rect = section.getBoundingClientRect();
        if (rect.top <= 120) {
          current = section.getAttribute('id');
        }
      });
      
      // Top nav
      navLinks.forEach(link => {
        link.classList.remove('active');
        if (link.getAttribute('href') === '#' + current) {
          link.classList.add('active');
        }
      });
      
      // Side nav dots
      sideNavDots.forEach(dot => {
        const span = dot.querySelector('span:last-child');
        if (dot.getAttribute('data-section') === current) {
          span.classList.remove('bg-slate-600');
          span.classList.add('bg-warm-amber', 'shadow-[0_0_8px_rgba(245,158,11,0.6)]');
        } else {
          span.classList.add('bg-slate-600');
          span.classList.remove('bg-warm-amber', 'shadow-[0_0_8px_rgba(245,158,11,0.6)]');
        }
      });
      
      // Show/hide side nav & back to top
      if (window.scrollY > 300) {
        sideNav.classList.remove('opacity-0');
        backToTop.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
      } else {
        sideNav.classList.add('opacity-0');
        backToTop.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
      }
    }
    
    // Back to top
    backToTop.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
    
    window.addEventListener('scroll', updateActiveNav);
    updateActiveNav();
  </script>

</body>
</html>
