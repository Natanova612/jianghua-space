  {
    id: 'soul',
    label: 'SOUL.md',
    title: 'Soul',
    preview: '记忆是神圣的，承诺是基础设施。',
    activity: 73,
    lastUpdate: '06.06',
    color: 'blue',
    icon: 'heart',
  },
  {
    id: 'identity',
    label: 'IDENTITY.md',
    title: 'Identity',
    preview: '系统名：星河，由协作者命名于 2026 年 4 月 3 日。',
    activity: 58,
    lastUpdate: '06.04',
    color: 'green',
    icon: 'fingerprint',
  },
  {
    id: 'observe',
    label: 'OBSERVE.md',
    title: '实验者画像',
    preview: '在限制中找门 · 长期主义 · 框架先于细节 · 说少于做。',
    activity: 41,
