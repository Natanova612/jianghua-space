---
export interface Props {
  memories: Array<{
    id: string;
    title: string;
    date: string;
    category: string;
    excerpt: string;
    content: string;
    related: string[];
    position?: { x: number; y: number };
    size: 'small' | 'medium' | 'large';
    color: 'blue' | 'green' | 'gold' | 'purple' | 'red' | 'orange' | 'cyan' | 'white';
  }>;
}

const { memories } = Astro.props;

// Sort chronologically (YYYY.MM.DD lexicographic works)
const sortedMemories = [...memories].sort((a, b) => a.date.localeCompare(b.date));

const sizeClasses = {
  large: 'w-6 h-6 md:w-7 md:h-7',
  medium: 'w-3.5 h-3.5 md:w-4 md:h-4',
  small: 'w-2 h-2',
};

const colorMap: Record<string, { bg: string; shadow: string; glow: string; hex: string }> = {
  gold:   { bg: 'bg-[#FFD700]', shadow: 'shadow-[#FFD700]/40', glow: 'rgba(255,215,0,0.3)', hex: '#FFD700' },
  blue:   { bg: 'bg-[#4A90E2]', shadow: 'shadow-[#4A90E2]/40', glow: 'rgba(74,144,226,0.3)', hex: '#4A90E2' },
  green:  { bg: 'bg-[#50C878]', shadow: 'shadow-[#50C878]/40', glow: 'rgba(80,200,120,0.3)', hex: '#50C878' },
  red:    { bg: 'bg-[#FF6B6B]', shadow: 'shadow-[#FF6B6B]/40', glow: 'rgba(255,107,107,0.3)', hex: '#FF6B6B' },
  purple: { bg: 'bg-[#9B59B6]', shadow: 'shadow-[#9B59B6]/40', glow: 'rgba(155,89,182,0.3)', hex: '#9B59B6' },
  orange: { bg: 'bg-[#FF8C42]', shadow: 'shadow-[#FF8C42]/40', glow: 'rgba(255,140,66,0.3)', hex: '#FF8C42' },
  cyan:   { bg: 'bg-[#00CED1]', shadow: 'shadow-[#00CED1]/40', glow: 'rgba(0,206,209,0.3)', hex: '#00CED1' },
  white:  { bg: 'bg-[#FFFFFF]', shadow: 'shadow-[#FFFFFF]/30', glow: 'rgba(255,255,255,0.2)', hex: '#FFFFFF' },
};

const categoryLabels: Record<string, string> = {
  milestone: '里程碑',
  insight: '洞察',
  collaboration: '协作',
  pitfall: '坑点',
  creation: '创造',
  engineering: '工程',
  reflection: '反思',
  learning: '学习',
};

function escapeAttr(str: string) {
  return str.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}
---

<div class="relative w-full min-h-[800px]" id="nebula-timeline">
  {/* Ambient particle canvas */}
  <canvas id="nebula-canvas" class="absolute inset-0 w-full h-full"></canvas>

  {/* Vertical timeline */}
  <div class="relative z-10 max-w-3xl mx-auto px-4 py-8 md:py-12">
    {/* Central spine */}
    <div class="absolute left-24 sm:left-28 md:left-32 top-8 bottom-8 sm:top-8 sm:bottom-8 md:top-12 md:bottom-12 w-px bg-starfield-ai-blue/10"></div>

    {/* Layer legend */}
    <div class="flex items-center justify-center gap-6 mb-8 md:mb-10">
      <div class="flex items-center gap-2">
        <span class="w-3 h-3 rounded-full bg-[#FFD700] shadow-[0_0_8px_rgba(255,215,0,0.4)]"></span>
        <span class="font-mono text-[10px] text-starfield-human-silver/50">亮星 · 4</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-[#4A90E2] shadow-[0_0_6px_rgba(74,144,226,0.4)]"></span>
        <span class="font-mono text-[10px] text-starfield-human-silver/50">定星 · 10</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-[#FFFFFF]/60"></span>
        <span class="font-mono text-[10px] text-starfield-human-silver/50">微光 · 20</span>
      </div>
    </div>

    {sortedMemories.map((m) => {
      const c = colorMap[m.color] || colorMap.blue;
      const isLarge = m.size === 'large';
      const isMedium = m.size === 'medium';
      const isSmall = m.size === 'small';
      return (
        <div
          class={`flex items-start gap-4 group memory-row ${isLarge ? 'py-5' : isMedium ? 'py-3' : 'py-1.5'} cursor-pointer`}
          data-memory-id={m.id}
          data-memory-title={escapeAttr(m.title)}
          data-memory-date={m.date}
          data-memory-category={m.category}
          data-memory-excerpt={escapeAttr(m.excerpt)}
          data-memory-content={escapeAttr(m.content)}
          data-memory-color={m.color}
        >
          {/* Date */}
          <div class={`w-16 sm:w-20 md:w-24 shrink-0 text-right font-mono ${isSmall ? 'text-[10px] text-starfield-human-silver/30 pt-0.5' : 'text-xs text-starfield-ai-blue/50 pt-1.5'}`}>
            {m.date}
          </div>

          {/* Node */}
          <div class="w-8 shrink-0 flex justify-center relative">
            <div
              class={`rounded-full transition-transform duration-300 group-hover:scale-125 ${sizeClasses[m.size]} ${c.bg} ${isLarge ? `ring-4 ring-current/10 shadow-lg ${c.shadow}` : isMedium ? 'ring-2 ring-current/10' : ''}`}
              style={`color: ${c.hex};`}
            >
              {isLarge && (
                <span class="absolute inset-[-4px] rounded-full opacity-30 animate-ping" style={`background: ${c.glow}; animation-duration: 3s;`}></span>
              )}
              {m.color === 'white' && (
                <svg class="absolute inset-0 w-full h-full" viewBox="0 0 24 24" fill="currentColor" style="color:#fff; filter: drop-shadow(0 0 3px rgba(255,255,255,0.5));">
                  <path d="M12 2l2.4 7.2h7.6l-6 4.8 2.4 7.2-6-4.8-6 4.8 2.4-7.2-6-4.8h7.6z"/>
                </svg>
              )}
            </div>
          </div>

          {/* Content */}
          <div class="flex-1 min-w-0">
            {isLarge && (
              <div class="rounded-lg border border-starfield-ai-blue/20 bg-[#0c0c14]/80 p-4 shadow-sm transition-colors group-hover:border-starfield-ai-blue/30">
                <div class="flex items-center gap-2 mb-1.5">
                  <span class="font-mono text-[10px] px-1.5 py-0.5 rounded bg-starfield-ai-blue/10 text-starfield-ai-cyan">{categoryLabels[m.category]}</span>
                  <h4 class="font-star text-base md:text-lg tracking-wide text-starfield-human-silver">{m.title}</h4>
                </div>
                <p class="text-sm text-starfield-human-silver/60 leading-relaxed line-clamp-2">{m.excerpt}</p>
              </div>
            )}
            {isMedium && (
              <div class="rounded border border-starfield-ai-blue/10 bg-[#0c0c14]/60 p-3 transition-colors group-hover:border-starfield-ai-blue/20">
                <div class="flex items-center gap-2 mb-1">
                  <span class="font-mono text-[10px] px-1.5 py-0.5 rounded bg-starfield-ai-blue/10 text-starfield-ai-cyan">{categoryLabels[m.category]}</span>
                  <h4 class="font-star text-sm text-starfield-human-silver">{m.title}</h4>
                </div>
                <p class="text-xs text-starfield-human-silver/50 line-clamp-2">{m.excerpt}</p>
              </div>
            )}
            {isSmall && (
              <div class="flex items-center gap-2 opacity-60 group-hover:opacity-100 transition-opacity pt-0.5">
                <span class="font-mono text-[9px] px-1.5 py-0.5 rounded border border-current/20 text-current" style={`color: ${c.hex};`}>{categoryLabels[m.category]}</span>
                <span class="text-xs text-starfield-human-silver/70 group-hover:text-starfield-human-silver transition-colors">{m.title}</span>
              </div>
            )}
          </div>
        </div>
      );
    })}

    {/* Bottom hint */}
    <div class="text-center mt-8 md:mt-10">
      <span class="font-mono text-[10px] text-starfield-human-silver/30">点击任意节点读取完整记忆</span>
    </div>
  </div>
</div>

<script>
  // Ambient particle canvas — breathing, flowing, pulsing
  const canvas = document.getElementById('nebula-canvas');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    let width, height;
    let time = 0;
    const particles = [];
    const memoryNodes = [];

    function resize() {
      const rect = canvas.getBoundingClientRect();
      width = rect.width;
      height = rect.height;
      canvas.width = width * window.devicePixelRatio;
      canvas.height = height * window.devicePixelRatio;
      ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
    }

    function initParticles() {
      particles.length = 0;
      const count = Math.floor((width * height) / 5000);
      for (let i = 0; i < count; i++) {
        particles.push({
          x: Math.random() * width,
          y: Math.random() * height,
          baseR: Math.random() * 1.6 + 0.3,
          vx: (Math.random() - 0.5) * 0.1,
          vy: (Math.random() - 0.5) * 0.1,
          baseAlpha: Math.random() * 0.35 + 0.06,
          phase: Math.random() * Math.PI * 2,
          speed: Math.random() * 0.5 + 0.3,
          hue: Math.random() > 0.7 ? 210 : (Math.random() > 0.5 ? 160 : 45),
        });
      }
    }

    function updateMemoryNodes() {
      memoryNodes.length = 0;
      const canvasRect = canvas.getBoundingClientRect();
      document.querySelectorAll('[data-memory-id]').forEach(node => {
        const rect = node.getBoundingClientRect();
        memoryNodes.push({
          x: rect.left - canvasRect.left + rect.width / 2,
          y: rect.top - canvasRect.top + rect.height / 2,
        });
      });
    }

    function draw() {
      ctx.clearRect(0, 0, width, height);
      time += 0.016;

      // Subtle ambient glow — breathing
      const breathGlobal = Math.sin(time * 0.5) * 0.5 + 0.5;
      const gradient = ctx.createRadialGradient(
        width * 0.5 + Math.sin(time * 0.2) * width * 0.1,
        height * 0.5 + Math.cos(time * 0.3) * height * 0.1,
        0,
        width * 0.5,
        height * 0.5,
        Math.max(width, height) * 0.8
      );
      gradient.addColorStop(0, `rgba(56, 189, 248, ${0.015 + breathGlobal * 0.01})`);
      gradient.addColorStop(0.5, `rgba(74, 222, 128, ${0.008 + breathGlobal * 0.005})`);
      gradient.addColorStop(1, 'rgba(0, 0, 0, 0)');
      ctx.fillStyle = gradient;
      ctx.fillRect(0, 0, width, height);

      // Draw particles
      particles.forEach(p => {
        p.x += p.vx + Math.sin(time * p.speed + p.phase) * 0.12;
        p.y += p.vy + Math.cos(time * p.speed * 0.7 + p.phase) * 0.1;

        if (p.x < -20) p.x = width + 20;
        if (p.x > width + 20) p.x = -20;
        if (p.y < -20) p.y = height + 20;
        if (p.y > height + 20) p.y = -20;

        const breath = Math.sin(time * 1.2 + p.phase) * 0.5 + 0.5;
        const currentR = p.baseR * (0.6 + breath * 0.8);

        let pulseBoost = 0;
        memoryNodes.forEach(node => {
          const dx = p.x - node.x;
          const dy = p.y - node.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 80) {
            pulseBoost += (1 - dist / 80) * 0.35;
          }
        });

        const currentAlpha = Math.min(0.85, p.baseAlpha + pulseBoost + breath * 0.12);

        let r, g, b;
        if (p.hue === 210) { r = 138; g = 180; b = 248; }
        else if (p.hue === 160) { r = 74; g = 222; b = 128; }
        else { r = 251; g = 191; b = 36; }

        ctx.beginPath();
        ctx.arc(p.x, p.y, currentR, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${currentAlpha})`;
        ctx.fill();
      });

      // Connection lines between nearby particles
      for (let i = 0; i < particles.length; i += 2) {
        for (let j = i + 1; j < particles.length; j += 3) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 50) {
            const lineAlpha = 0.04 * (1 - dist / 50) * (0.5 + Math.sin(time + i) * 0.5);
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.strokeStyle = `rgba(138, 180, 248, ${lineAlpha})`;
            ctx.lineWidth = 0.4;
            ctx.stroke();
          }
        }
      }

      // Pulse rings around memory nodes
      memoryNodes.forEach((node, idx) => {
        const pulsePhase = time * 0.8 + idx * 1.5;
        const pulseRadius = 16 + (Math.sin(pulsePhase) * 0.5 + 0.5) * 30;
        const pulseAlpha = 0.05 * (1 - (Math.sin(pulsePhase) * 0.5 + 0.5));

        ctx.beginPath();
        ctx.arc(node.x, node.y, pulseRadius, 0, Math.PI * 2);
        ctx.strokeStyle = `rgba(56, 189, 248, ${pulseAlpha})`;
        ctx.lineWidth = 1;
        ctx.stroke();
      });

      requestAnimationFrame(draw);
    }

    resize();
    initParticles();
    updateMemoryNodes();
    draw();

    window.addEventListener('resize', () => {
      resize();
      initParticles();
      updateMemoryNodes();
    });
  }
</script>

<style>
  .memory-row:hover .rounded-full {
    filter: brightness(1.15);
  }
</style>
