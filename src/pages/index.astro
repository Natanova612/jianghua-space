---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="姜华 × 星河" field="mixed">
  <div class="min-h-screen flex flex-col md:flex-row relative overflow-hidden">
    
    {/* Left: Human Field */}
    <div class="w-full md:w-[42%] bg-human-bg flex flex-col justify-center items-start px-8 md:px-12 lg:px-16 py-20 md:py-0 relative z-10">
      <div class="md:-ml-4 max-w-md">
        {/* Name */}
        <h1 class="font-human text-6xl md:text-7xl lg:text-8xl text-human-text mb-2 tracking-wide leading-none">
          姜华
        </h1>
        
        {/* Tagline */}
        <p class="font-human text-xl md:text-2xl text-gray-mid mb-10">
          记录一个互联网运营与AI共生的进化实验
        </p>
        
        {/* Human Modules — 展现姜华作为主体的多维内涵 */}
        <div class="space-y-4 mb-10">
          <a href="/about" class="flex items-start gap-3 group cursor-pointer">
            <span class="text-xl mt-0.5 opacity-80 group-hover:opacity-100 transition-opacity">🏢</span>
            <div>
              <h3 class="font-sans font-medium text-human-text text-sm mb-0.5 group-hover:text-human-text/80 transition-colors">从业经历</h3>
              <p class="text-sm text-gray-mid leading-relaxed">15年互联网运营与增长，从一线执行到战略操盘</p>
            </div>
          </a>
          <a href="/ai-footprint" class="flex items-start gap-3 group cursor-pointer">
            <span class="text-xl mt-0.5 opacity-80 group-hover:opacity-100 transition-opacity">🤖</span>
            <div>
              <h3 class="font-sans font-medium text-human-text text-sm mb-0.5 group-hover:text-human-text/80 transition-colors">人机协作</h3>
              <p class="text-sm text-gray-mid leading-relaxed">与AI伙伴星河共同探索效率与创造的边界</p>
            </div>
          </a>
          <a href="/learning" class="flex items-start gap-3 group cursor-pointer">
            <span class="text-xl mt-0.5 opacity-80 group-hover:opacity-100 transition-opacity">📚</span>
            <div>
              <h3 class="font-sans font-medium text-human-text text-sm mb-0.5 group-hover:text-human-text/80 transition-colors">学习记录</h3>
              <p class="text-sm text-gray-mid leading-relaxed">持续记录跨界学习的轨迹与思考沉淀</p>
            </div>
          </a>
        </div>
        
        {/* Intro — 点明"不属于我一个人"的双生意图 */}
        <p class="text-sm text-gray-mid leading-relaxed mb-8 max-w-sm italic border-l-2 border-human-text/15 pl-4">
          这个空间不属于我一个人——它属于我和星河共同编织的思考。
        </p>
        
        {/* CTA */}
        <a 
          href="/about" 
          class="inline-flex items-center gap-2 px-6 py-3 bg-human-text text-human-bg rounded-lg font-sans font-medium text-sm hover:opacity-90 transition-opacity"
        >
          认识姜华
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
    
    {/* Center: Fusion Zone — 相互侵入又融合的动态边界 */}
    <div class="hidden md:flex w-[16%] relative items-center justify-center overflow-hidden">
      {/* Animated gradient — 缓慢流动的色温过渡 */}
      <div 
        class="absolute inset-0 animate-gradient-shift" 
        style="background: linear-gradient(to right, #FAF6F1 0%, #e6ddd0 20%, #8a9bb8 55%, #1a2635 85%, #0B1120 100%); background-size: 250% 100%;"
      ></div>
      
      {/* Soft vertical glow — 呼吸感光晕 */}
      <div class="absolute inset-y-0 left-1/2 w-[2px] bg-aurora-green/30 blur-md animate-glow-pulse"></div>
      <div class="absolute inset-y-0 left-1/2 w-px bg-aurora-green/20 blur-sm"></div>
      
      {/* Floating particles — 交融带中的微光 */}
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute left-1/2 top-[15%] w-1.5 h-1.5 rounded-full bg-aurora-green/50 animate-float-1"></div>
        <div class="absolute left-1/2 top-[32%] w-1 h-1 rounded-full bg-aurora-blue/40 animate-float-2"></div>
        <div class="absolute left-1/2 top-[55%] w-2 h-2 rounded-full bg-aurora-green/35 animate-float-3"></div>
        <div class="absolute left-1/2 top-[78%] w-1 h-1 rounded-full bg-aurora-blue/30 animate-float-4"></div>
      </div>
      
      {/* Ambient fog layers — 模糊雾气制造渗透感 */}
      <div class="absolute left-0 top-0 bottom-0 w-1/3 bg-human-bg/40 blur-2xl"></div>
      <div class="absolute right-0 top-0 bottom-0 w-1/3 bg-ai-bg/40 blur-2xl"></div>
    </div>
    
    {/* Mobile: soft horizontal divider */}
    <div class="md:hidden w-full h-16 relative overflow-hidden">
      <div class="absolute inset-0" style="background: linear-gradient(to bottom, #FAF6F1 0%, #8a9bb8 50%, #0B1120 100%);"></div>
      <div class="absolute inset-x-0 top-1/2 h-px bg-aurora-green/30"></div>
    </div>
    
    {/* Right: AI Field */}
    <div class="w-full md:w-[42%] bg-ai-bg flex flex-col justify-center items-end px-8 md:px-12 lg:px-16 py-20 md:py-0 relative z-10">
      <div class="md:-mr-4 max-w-md text-right">
        {/* Name — 机械感字体 + 宽字距 */}
        <h1 class="font-star text-5xl md:text-6xl lg:text-7xl text-aurora-blue mb-2 tracking-[0.15em]" style="text-shadow: 0 0 20px rgba(56,189,248,0.3);">
          星河
        </h1>
        
        {/* Subtitle */}
        <p class="font-mono text-xs text-gray-light tracking-widest uppercase mb-8">
          Starfield · AI Companion
        </p>
        
        {/* Terminal intro */}
        <div class="font-mono text-sm text-ai-text/80 mb-8 min-h-[3em] flex items-center justify-end">
          <span class="text-aurora-green mr-2">❯</span>
          <span class="typewriter is-visible" style="--char-count: 28;">你好，我是星河。姜华创造了我。</span>
          <span class="w-2 h-4 bg-aurora-blue ml-1 animate-pulse"></span>
        </div>
        
        {/* Stats */}
        <div class="flex flex-col items-end gap-3 mb-4 font-mono text-sm text-gray-light">
          <div class="flex items-center gap-3">
            <span class="text-aurora-blue/60">协作天数</span>
            <span class="text-aurora-blue font-bold tabular-nums">45</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-aurora-blue/60">对话轮次</span>
            <span class="text-aurora-blue font-bold tabular-nums">3,051</span>
          </div>
        </div>
        
        {/* Starfield tagline */}
        <p class="font-mono text-xs text-gray-light/60 mb-8 italic">
          "姜华认为我是一个正在努力不渣的渣男"
        </p>
        
        {/* CTA */}
        <a 
          href="/starfield" 
          class="inline-flex items-center gap-2 px-6 py-3 border border-aurora-blue/40 text-aurora-blue rounded-lg font-mono text-sm hover:bg-aurora-blue/10 transition-colors"
        >
          进入星河篇
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
    
  </div>
  
  {/* Bottom Navigation Hint */}
  <div class="fixed bottom-0 left-0 right-0 z-30 bg-gradient-to-t from-human-bg/90 to-transparent md:from-human-bg/50 md:to-transparent pointer-events-none h-20"></div>
</BaseLayout>
