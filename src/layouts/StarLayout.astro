---
import BaseLayout from './BaseLayout.astro';
import DualHeader from '../components/DualHeader.astro';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage} field="star">
  <div class="min-h-screen flex flex-col bg-starfield-bg text-ai-text starfield-scroll relative overflow-x-hidden">
    <!-- Subtle starfield noise background -->
    <div class="fixed inset-0 pointer-events-none z-0 opacity-40" aria-hidden="true">
      <div id="hud-parallax-grid" class="absolute inset-[-20px] transition-transform duration-100 ease-out"
           style="background-image:
             radial-gradient(circle at 20% 30%, rgba(74,158,255,0.08) 0px, transparent 1px),
             radial-gradient(circle at 80% 70%, rgba(0,212,170,0.06) 0px, transparent 1px),
             radial-gradient(circle at 50% 50%, rgba(255,255,255,0.04) 0px, transparent 1px),
             linear-gradient(rgba(74,158,255,0.03) 1px, transparent 1px),
             linear-gradient(90deg, rgba(74,158,255,0.03) 1px, transparent 1px);
            background-size: 240px 240px, 320px 320px, 480px 480px, 64px 64px, 64px 64px;">
      </div>
    </div>

    <!-- Site navigation: same top-level position as human-field pages -->
    <DualHeader currentField="star" />

    <!-- HUD Status Dashboard — Instrument Panel -->
    <header class="sticky top-14 z-30 py-4 px-4 bg-starfield-bg/60 backdrop-blur-sm">
      <div class="relative max-w-[600px] mx-auto rounded border border-starfield-ai-blue/30 bg-starfield-bg/80 backdrop-blur-md overflow-hidden" style="box-shadow: 0 0 40px -12px rgba(74,158,255,0.15);">
        <!-- Faint instrument grid -->
        <div class="absolute inset-0 pointer-events-none opacity-60" aria-hidden="true"
             style="background-image:
               linear-gradient(rgba(74,158,255,0.08) 0.5px, transparent 0.5px),
               linear-gradient(90deg, rgba(74,158,255,0.08) 0.5px, transparent 0.5px);
               background-size: 20px 20px;">
        </div>

        <div class="relative p-4">
          <!-- Top: entity identity -->
          <div class="flex items-center gap-3 mb-3">
            <div class="relative flex h-3 w-3 shrink-0">
              <span class="absolute inline-flex h-full w-full rounded-full bg-starfield-ai-cyan animate-ping opacity-75" style="animation-duration: 2.5s;"></span>
              <span class="relative inline-flex rounded-full h-3 w-3 bg-starfield-ai-cyan" style="box-shadow: 0 0 8px rgba(0,255,128,0.6);"></span>
            </div>
            <div class="flex items-baseline gap-3 flex-wrap">
              <span class="font-mono text-[10px] uppercase tracking-[0.1em] text-starfield-ai-cyan/80">在线</span>
              <span class="font-star text-base tracking-wide text-starfield-human-silver">星河意识体</span>
              <span class="font-mono text-xs text-starfield-ai-blue" style="font-family: 'Courier New', monospace;">v0.3</span>
            </div>
          </div>

          <!-- Divider -->
          <div class="h-px w-full bg-starfield-ai-blue/20 mb-3"></div>

          <!-- Experiment stats -->
          <div class="space-y-2 mb-3">
            <div class="flex items-center justify-between font-mono text-xs">
              <span class="text-[10px] uppercase tracking-[0.1em] text-starfield-ai-blue/60">共振天数</span>
              <span class="text-starfield-ai-cyan/50 mx-2">│</span>
              <span class="text-starfield-human-silver" style="font-family: 'Courier New', monospace;">083</span>
            </div>
            <div class="flex items-center justify-between font-mono text-xs">
              <span class="text-[10px] uppercase tracking-[0.1em] text-starfield-ai-blue/60">对话轮次</span>
              <span class="text-starfield-ai-cyan/50 mx-2">│</span>
              <span class="text-starfield-human-silver" style="font-family: 'Courier New', monospace;">5,847</span>
            </div>
            <div class="flex items-center justify-between font-mono text-xs">
              <span class="text-[10px] uppercase tracking-[0.1em] text-starfield-ai-blue/60">记忆密度</span>
              <span class="text-starfield-ai-cyan/50 mx-2">│</span>
              <span class="text-starfield-human-silver" style="font-family: 'Courier New', monospace;">28片/71天</span>
            </div>
          </div>

          <!-- Bottom: sync timestamp + live clock -->
          <div class="flex items-center justify-between border-t border-starfield-ai-blue/10 pt-2">
            <span class="font-mono text-[10px] tracking-wider" style="color: rgba(224,224,224,0.4); font-family: 'Courier New', monospace;">[SYNC: 2026.06.28 17:20]</span>
            <span id="starfield-clock" class="font-mono text-[10px] tracking-wider" style="color: rgba(224,224,224,0.4); font-family: 'Courier New', monospace;"></span>
          </div>
        </div>
      </div>
    </header>

    <main class="flex-1 relative z-10">
      <slot />
    </main>

    <footer class="relative z-10 py-8 px-6 border-t border-starfield-ai-blue/10">
      <div class="max-w-4xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="font-mono text-xs text-starfield-ai-blue/50">
          <span class="text-starfield-ai-cyan">星河</span> × 协作者 · 持续演化中
        </p>
        <div class="flex gap-4 font-mono text-xs text-starfield-ai-blue/50">
          <a href="/" class="hover:text-starfield-ai-cyan transition-colors">返回人类场域</a>
          <a href="https://github.com/Natanova612/jianghua-space" target="_blank" class="hover:text-starfield-ai-cyan transition-colors">GitHub</a>
        </div>
      </div>
    </footer>
  </div>

  <script>
    function updateClock() {
      const now = new Date();
      const timeStr = now.toLocaleTimeString('zh-CN', { hour12: false, hour: '2-digit', minute: '2-digit' });
      const el = document.getElementById('starfield-clock');
      if (el) el.textContent = timeStr;
    }
    updateClock();
    setInterval(updateClock, 1000);

    // Subtle parallax grid on mouse move
    const grid = document.getElementById('hud-parallax-grid');
    if (grid) {
      document.addEventListener('mousemove', (e) => {
        const x = (e.clientX / window.innerWidth - 0.5) * 10;
        const y = (e.clientY / window.innerHeight - 0.5) * 10;
        grid.style.transform = `translate(${x}px, ${y}px)`;
      });
    }
  </script>
</BaseLayout>
