---
export interface Props {
  memories: Array<{
    id: string;
    title: string;
    date: string;
    category: string;
    excerpt: string;
    content: string;
    related: string[];
    position: { x: number; y: number };
    size: 'small' | 'medium' | 'large';
    color: 'blue' | 'green' | 'gold' | 'purple';
  }>;
}

const { memories } = Astro.props;

const sizeMap = {
  small: 'w-3 h-3',
  medium: 'w-4 h-4',
  large: 'w-7 h-7',
};

const colorMap: Record<string, { bg: string; shadow: string; glow: string; hex: string }> = {
  gold:   { bg: 'bg-[#FFD700]', shadow: 'shadow-[#FFD700]/40', glow: 'rgba(255,215,0,0.3)', hex: '#FFD700' },
  blue:   { bg: 'bg-[#4A90E2]', shadow: 'shadow-[#4A90E2]/40', glow: 'rgba(74,144,226,0.3)', hex: '#4A90E2' },
  green:  { bg: 'bg-[#50C878]', shadow: 'shadow-[#50C878]/40', glow: 'rgba(80,200,120,0.3)', hex: '#50C878' },
  red:    { bg: 'bg-[#FF6B6B]', shadow: 'shadow-[#FF6B6B]/40', glow: 'rgba(255,107,107,0.3)', hex: '#FF6B6B' },
  purple: { bg: 'bg-[#9B59B6]', shadow: 'shadow-[#9B59B6]/40', glow: 'rgba(155,89,182,0.3)', hex: '#9B59B6' },
  orange: { bg: 'bg-[#FF8C42]', shadow: 'shadow-[#FF8C42]/40', glow: 'rgba(255,140,66,0.3)', hex: '#FF8C42' },
  cyan:   { bg: 'bg-[#00CED1]', shadow: 'shadow-[#00CED1]/40', glow: 'rgba(0,206,209,0.3)', hex: '#00CED1' },
  white:  { bg: 'bg-[#FFFFFF]', shadow: 'shadow-[#FFFFFF]/30', glow: 'rgba(255,255,255,0.2)', hex: '#FFFFFF' },
};

const categoryLabels: Record<string, string> = {
  milestone: '里程碑',
  insight: '洞察',
  collaboration: '协作',
  pitfall: '坑点',
  creation: '创造',
  engineering: '工程',
  reflection: '反思',
  learning: '学习',
};

// Build connection lines between related memories
const connections: Array<{ from: { x: number; y: number }; to: { x: number; y: number } }> = [];
memories.forEach(m => {
  m.related.forEach(relatedId => {
    const target = memories.find(t => t.id === relatedId);
    if (target) {
      // Only add each connection once (avoid duplicates)
      const exists = connections.some(c => 
        (c.from.x === m.position.x && c.from.y === m.position.y && c.to.x === target.position.x && c.to.y === target.position.y) ||
        (c.from.x === target.position.x && c.from.y === target.position.y && c.to.x === m.position.x && c.to.y === m.position.y)
      );
      if (!exists) {
        connections.push({ from: m.position, to: target.position });
      }
    }
  });
});
---

<div class="relative w-full" style="height: 600px;">
  {/* Background particles */}
  <canvas id="nebula-canvas" class="absolute inset-0 w-full h-full"></canvas>
  
  {/* Connection lines */}
  <svg class="absolute inset-0 w-full h-full pointer-events-none" preserveAspectRatio="none">
    {connections.map((conn, i) => (
      <line
        x1={`${conn.from.x}%`}
        y1={`${conn.from.y}%`}
        x2={`${conn.to.x}%`}
        y2={`${conn.to.y}%`}
        stroke="rgba(56,189,248,0.12)"
        stroke-width="1"
        class="animate-pulse"
        style={`animation-delay: ${i * 0.3}s; animation-duration: ${4 + (i % 3)}s;`}
      />
    ))}
  </svg>
  
  {/* Memory nodes */}
  {memories.map((m, i) => {
    const c = colorMap[m.color] || colorMap.blue;
    return (
      <div
        class={`absolute cursor-pointer group z-10 ${sizeMap[m.size]} ${c.bg} ${c.shadow} rounded-full shadow-lg transition-transform duration-300 hover:scale-150 star-twinkle`}
        style={`left: ${m.position.x}%; top: ${m.position.y}%; transform: translate(-50%, -50%); animation-delay: ${i * 0.4}s;`}
        data-memory-id={m.id}
        data-memory-title={m.title}
        data-memory-date={m.date}
        data-memory-category={m.category}
        data-memory-excerpt={m.excerpt}
        data-memory-content={m.content}
        data-memory-color={m.color}
      >
        {/* Glow ring */}
        <span class="absolute inset-[-6px] rounded-full opacity-20" style={`background: radial-gradient(circle, ${c.glow} 0%, transparent 70%);`}></span>
        
        {/* Pulse ring for large nodes */}
        {m.size === 'large' && (
          <span class={`absolute inset-[-4px] rounded-full opacity-40 animate-ping`} style={`background: ${c.glow}; animation-duration: 3s;`}></span>
        )}
        
        {/* Star shape for white nodes */}
        {m.color === 'white' && (
          <svg class="absolute inset-0 w-full h-full" viewBox="0 0 24 24" fill="currentColor" style="color:#fff; filter: drop-shadow(0 0 4px rgba(255,255,255,0.6));">
            <path d="M12 2l2.4 7.2h7.6l-6 4.8 2.4 7.2-6-4.8-6 4.8 2.4-7.2-6-4.8h7.6z"/>
          </svg>
        )}
        
        {/* Tooltip */}
        <div class="absolute left-1/2 -translate-x-1/2 bottom-full mb-3 opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none z-20 w-48">
          <div class="bg-ai-bg/95 backdrop-blur-sm border border-gray-deep/50 rounded-lg p-3 shadow-xl">
            <div class="flex items-center justify-between mb-1">
              <span class="font-mono text-xs text-gray-light">{m.date}</span>
              <span class="font-mono text-[10px] px-1.5 py-0.5 rounded bg-gray-deep/50 text-gray-light">{categoryLabels[m.category]}</span>
            </div>
            <h4 class="font-star text-sm text-ai-text mb-1">{m.title}</h4>
            <p class="text-xs text-gray-light leading-relaxed line-clamp-2">{m.excerpt}</p>
          </div>
          <div class="w-2 h-2 bg-ai-bg/95 border-r border-b border-gray-deep/50 rotate-45 absolute left-1/2 -translate-x-1/2 -bottom-1"></div>
        </div>
      </div>
    );
  })},
  
  {/* Legend */}
  <div class="absolute bottom-4 left-4 flex flex-wrap gap-x-4 gap-y-2 max-w-[70%]">
    {Object.entries(categoryLabels).map(([key, label]) => {
      const colorHex = {
        milestone: '#FFD700',
        insight: '#4A90E2',
        collaboration: '#50C878',
        pitfall: '#FF6B6B',
        creation: '#9B59B6',
        engineering: '#FF8C42',
        reflection: '#00CED1',
        learning: '#FFFFFF',
      }[key];
      return (
        <div class="flex items-center gap-1.5">
          <span class="w-2 h-2 rounded-full" style={`background-color: ${colorHex}; box-shadow: 0 0 6px ${colorHex};`}></span>
          <span class="font-mono text-[10px] text-gray-light">{label}</span>
        </div>
      );
    })}
  </div>
  
  {/* Hint */}
  <div class="absolute bottom-4 right-4 font-mono text-[10px] text-gray-light/50">
    点击碎片查看记忆
  </div>
</div>

{/* Memory detail modal */}
<div id="memory-modal" class="fixed inset-0 z-[100] hidden">
  <div class="absolute inset-0 bg-ai-bg/90 backdrop-blur-md" data-close-memory></div>
  <div class="absolute inset-x-4 top-[8%] md:inset-x-auto md:left-1/2 md:-translate-x-1/2 md:w-[600px] max-h-[84vh] overflow-y-auto rounded-xl border border-gray-deep/50 bg-ai-bg p-8">
    <div class="flex items-center justify-between mb-2">
      <span id="memory-modal-date" class="font-mono text-xs text-gray-light"></span>
      <button data-close-memory class="text-gray-light hover:text-ai-text transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <span id="memory-modal-category" class="inline-block font-mono text-[10px] px-2 py-0.5 rounded bg-gray-deep/50 text-gray-light mb-4"></span>
    <h3 id="memory-modal-title" class="font-star text-2xl tracking-wide mb-6 text-ai-text"></h3>
    <div id="memory-modal-content" class="font-mono text-sm text-ai-text/80 leading-[1.875]"></div>
  </div>
</div>

<script>
  // Background particle canvas — breathing, flowing, pulsing
  const canvas = document.getElementById('nebula-canvas');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    let width, height;
    let time = 0;
    const particles = [];
    const memoryNodes = [];
    
    function resize() {
      const rect = canvas.getBoundingClientRect();
      width = rect.width;
      height = rect.height;
      canvas.width = width * window.devicePixelRatio;
      canvas.height = height * window.devicePixelRatio;
      ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
    }
    
    function initParticles() {
      particles.length = 0;
      const count = Math.floor((width * height) / 4000);
      for (let i = 0; i < count; i++) {
        particles.push({
          x: Math.random() * width,
          y: Math.random() * height,
          baseR: Math.random() * 1.8 + 0.4,
          vx: (Math.random() - 0.5) * 0.12,
          vy: (Math.random() - 0.5) * 0.12,
          baseAlpha: Math.random() * 0.4 + 0.08,
          phase: Math.random() * Math.PI * 2,
          speed: Math.random() * 0.6 + 0.4,
          hue: Math.random() > 0.7 ? 210 : (Math.random() > 0.5 ? 160 : 45),
        });
      }
    }
    
    function updateMemoryNodes() {
      memoryNodes.length = 0;
      const canvasRect = canvas.getBoundingClientRect();
      document.querySelectorAll('[data-memory-id]').forEach(node => {
        const rect = node.getBoundingClientRect();
        memoryNodes.push({
          x: rect.left - canvasRect.left + rect.width / 2,
          y: rect.top - canvasRect.top + rect.height / 2,
        });
      });
    }
    
    function draw() {
      ctx.clearRect(0, 0, width, height);
      time += 0.016;
      
      // Subtle ambient glow — breathing
      const breathGlobal = Math.sin(time * 0.5) * 0.5 + 0.5;
      const gradient = ctx.createRadialGradient(
        width * 0.5 + Math.sin(time * 0.2) * width * 0.1,
        height * 0.5 + Math.cos(time * 0.3) * height * 0.1,
        0,
        width * 0.5,
        height * 0.5,
        Math.max(width, height) * 0.8
      );
      gradient.addColorStop(0, `rgba(56, 189, 248, ${0.015 + breathGlobal * 0.01})`);
      gradient.addColorStop(0.5, `rgba(74, 222, 128, ${0.008 + breathGlobal * 0.005})`);
      gradient.addColorStop(1, 'rgba(0, 0, 0, 0)');
      ctx.fillStyle = gradient;
      ctx.fillRect(0, 0, width, height);
      
      // Draw particles
      particles.forEach(p => {
        // Flowing drift
        p.x += p.vx + Math.sin(time * p.speed + p.phase) * 0.15;
        p.y += p.vy + Math.cos(time * p.speed * 0.7 + p.phase) * 0.12;
        
        // Wrap around
        if (p.x < -20) p.x = width + 20;
        if (p.x > width + 20) p.x = -20;
        if (p.y < -20) p.y = height + 20;
        if (p.y > height + 20) p.y = -20;
        
        // Breathing — size oscillation
        const breath = Math.sin(time * 1.2 + p.phase) * 0.5 + 0.5;
        const currentR = p.baseR * (0.6 + breath * 0.8);
        
        // Pulsing — brighter near memory nodes
        let pulseBoost = 0;
        memoryNodes.forEach(node => {
          const dx = p.x - node.x;
          const dy = p.y - node.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 100) {
            pulseBoost += (1 - dist / 100) * 0.4;
          }
        });
        
        const currentAlpha = Math.min(0.9, p.baseAlpha + pulseBoost + breath * 0.15);
        
        // Color based on hue
        let r, g, b;
        if (p.hue === 210) { r = 138; g = 180; b = 248; }
        else if (p.hue === 160) { r = 74; g = 222; b = 128; }
        else { r = 251; g = 191; b = 36; }
        
        ctx.beginPath();
        ctx.arc(p.x, p.y, currentR, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${currentAlpha})`;
        ctx.fill();
      });
      
      // Connection lines between nearby particles — flowing web
      for (let i = 0; i < particles.length; i += 2) {
        for (let j = i + 1; j < particles.length; j += 3) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 50) {
            const lineAlpha = 0.04 * (1 - dist / 50) * (0.5 + Math.sin(time + i) * 0.5);
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.strokeStyle = `rgba(138, 180, 248, ${lineAlpha})`;
            ctx.lineWidth = 0.4;
            ctx.stroke();
          }
        }
      }
      
      // Pulse rings around memory nodes
      memoryNodes.forEach((node, idx) => {
        const pulsePhase = time * 0.8 + idx * 1.5;
        const pulseRadius = 20 + (Math.sin(pulsePhase) * 0.5 + 0.5) * 40;
        const pulseAlpha = 0.06 * (1 - (Math.sin(pulsePhase) * 0.5 + 0.5));
        
        ctx.beginPath();
        ctx.arc(node.x, node.y, pulseRadius, 0, Math.PI * 2);
        ctx.strokeStyle = `rgba(56, 189, 248, ${pulseAlpha})`;
        ctx.lineWidth = 1;
        ctx.stroke();
      });
      
      requestAnimationFrame(draw);
    }
    
    resize();
    initParticles();
    updateMemoryNodes();
    draw();
    
    window.addEventListener('resize', () => {
      resize();
      initParticles();
      updateMemoryNodes();
    });
  }

  // Memory node interactions
  document.querySelectorAll('[data-memory-id]').forEach(node => {
    node.addEventListener('click', () => {
      const title = node.getAttribute('data-memory-title');
      const date = node.getAttribute('data-memory-date');
      const category = node.getAttribute('data-memory-category');
      const content = node.getAttribute('data-memory-content');
      const color = node.getAttribute('data-memory-color');
      
      const categoryLabels: Record<string, string> = {
        milestone: '里程碑',
        insight: '洞察',
        collaboration: '协作',
        pitfall: '坑点',
        creation: '创造',
        engineering: '工程',
        reflection: '反思',
        learning: '学习',
      };
      
      const colorHex: Record<string, string> = {
        gold: '#FFD700',
        blue: '#4A90E2',
        green: '#50C878',
        red: '#FF6B6B',
        purple: '#9B59B6',
        orange: '#FF8C42',
        cyan: '#00CED1',
        white: '#FFFFFF',
      };
      
      document.getElementById('memory-modal-date').textContent = date;
      const catEl = document.getElementById('memory-modal-category');
      catEl.textContent = categoryLabels[category] || category;
      catEl.style.color = colorHex[color] || '#94a3b8';
      document.getElementById('memory-modal-title').textContent = title;
      document.getElementById('memory-modal-content').textContent = content;
      document.getElementById('memory-modal').classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    });
  });

  document.querySelectorAll('[data-close-memory]').forEach(el => {
    el.addEventListener('click', () => {
      document.getElementById('memory-modal').classList.add('hidden');
      document.body.style.overflow = '';
    });
  });

  document.getElementById('memory-modal').addEventListener('click', (e) => {
    if (e.target.id === 'memory-modal') {
      document.getElementById('memory-modal').classList.add('hidden');
      document.body.style.overflow = '';
    }
  });
</script>

<style>
  .star-twinkle {
    animation: starTwinkle 3s ease-in-out infinite;
  }
  @keyframes starTwinkle {
    0%, 100% { opacity: 1; filter: brightness(1); }
    50% { opacity: 0.65; filter: brightness(0.8); }
  }
</style>
