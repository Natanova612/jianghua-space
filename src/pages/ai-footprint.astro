---
import HumanLayout from '../layouts/HumanLayout.astro';
import { getCollection } from 'astro:content';

const tools = await getCollection('tools');
const cases = await getCollection('cases');

// Sort cases by date descending
const sortedCases = [...cases].sort((a, b) => {
  const dateA = a.data.date.replace('.', '');
  const dateB = b.data.date.replace('.', '');
  return dateB.localeCompare(dateA);
});

// Fusion dimensions
const dimensions = [
  { name: '工作运营', level: 85, color: 'bg-aurora-blue' },
  { name: '内容创作', level: 75, color: 'bg-aurora-green' },
  { name: '学习研究', level: 95, color: 'bg-resonance-gold' },
  { name: '生活决策', level: 70, color: 'bg-purple-400' },
  { name: '代码开发', level: 90, color: 'bg-aurora-blue' },
];

const typeLabels: Record<string, { label: string; color: string; bg: string }> = {
  research: { label: '研究', color: 'text-aurora-blue', bg: 'bg-aurora-blue/10 border-aurora-blue/20' },
  application: { label: '应用', color: 'text-aurora-green', bg: 'bg-aurora-green/10 border-aurora-green/20' },
  insight: { label: '心得', color: 'text-resonance-gold', bg: 'bg-resonance-gold/10 border-resonance-gold/20' },
  pitfall: { label: '坑点', color: 'text-red-400', bg: 'bg-red-400/10 border-red-400/20' },
};
---

<HumanLayout title="AI应用足迹" description="姜华的AI画像与应用案例集">
  <div class="relative">
    <div class="absolute inset-x-0 top-0 h-64 bg-gradient-to-b from-human-bg via-human-bg to-ai-bg/5 pointer-events-none"></div>
    
    <div class="relative max-w-5xl mx-auto px-6 py-16 md:py-24">
      
      {/* Header */}
      <div class="mb-16 scroll-reveal">
        <h1 class="font-human text-3xl md:text-4xl text-human-text mb-4">AI 应用足迹</h1>
        <p class="text-gray-mid max-w-lg">
          不是工具清单，而是我的 AI 融合度画像——以及我在人机协作中积累的真实案例。
        </p>
      </div>
      
      {/* ========== Two-column layout: Cases main + Profile sidebar ========== */}
      <div class="grid md:grid-cols-3 gap-8">
        
        {/* ========== MAIN: AI应用案例 ========== */}
        <div class="md:col-span-2">
          <div class="flex items-center gap-4 mb-8">
            <span class="font-mono text-xs text-gray-light/50 tracking-widest">CASES</span>
            <div class="h-px flex-1 bg-gray-100"></div>
          </div>
          
          <h2 class="font-human text-xl text-human-text mb-2">应用案例</h2>
          <p class="text-sm text-gray-mid mb-6">真实的人机协作故事——研究、应用、心得与踩过的坑。</p>
          
          {/* Filter tabs */}
          <div class="flex flex-wrap gap-2 mb-6" id="case-filters">
            <button class="filter-btn active px-4 py-1.5 rounded-full text-xs font-mono border border-human-text bg-human-text text-human-bg transition-all" data-filter="all">全部</button>
            <button class="filter-btn px-4 py-1.5 rounded-full text-xs font-mono border border-gray-200 text-gray-mid hover:border-aurora-blue hover:text-aurora-blue transition-all" data-filter="research">研究</button>
            <button class="filter-btn px-4 py-1.5 rounded-full text-xs font-mono border border-gray-200 text-gray-mid hover:border-aurora-green hover:text-aurora-green transition-all" data-filter="application">应用</button>
            <button class="filter-btn px-4 py-1.5 rounded-full text-xs font-mono border border-gray-200 text-gray-mid hover:border-resonance-gold hover:text-resonance-gold transition-all" data-filter="insight">心得</button>
            <button class="filter-btn px-4 py-1.5 rounded-full text-xs font-mono border border-gray-200 text-gray-mid hover:border-red-400 hover:text-red-400 transition-all" data-filter="pitfall">坑点</button>
          </div>
          
          {/* Case cards */}
          <div class="space-y-4" id="case-list">
            {sortedCases.map(c => {
              const typeStyle = typeLabels[c.data.type];
              return (
                <div 
                  class="case-card group p-6 rounded-xl border border-gray-200/60 bg-human-bg/30 hover:bg-human-bg hover:border-gray-300 transition-all cursor-pointer scroll-reveal"
                  data-case-type={c.data.type}
                  data-case-title={c.data.title}
                  data-case-date={c.data.date}
                  data-case-type-label={typeStyle.label}
                  data-case-type-color={typeStyle.color}
                  data-case-type-bg={typeStyle.bg}
                  data-case-content={c.data.content}
                >
                  <div class="flex flex-col md:flex-row md:items-start gap-4">
                    {/* Type badge */}
                    <div class="shrink-0">
                      <span class={`inline-block px-3 py-1 rounded-full text-xs font-mono border ${typeStyle.bg} ${typeStyle.color}`}>
                        {typeStyle.label}
                      </span>
                    </div>
                    
                    {/* Content */}
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-3 mb-2">
                        <h3 class="font-human text-lg font-bold text-human-text inline-block px-2 py-0.5 rounded bg-amber-100/40 group-hover:text-aurora-green transition-colors">{c.data.title}</h3>
                        <span class="text-xs font-mono text-gray-light">{c.data.date}</span>
                      </div>
                      <p class="text-sm text-gray-mid leading-relaxed mb-3">{c.data.excerpt}</p>
                      <div class="flex flex-wrap gap-2">
                        {c.data.tags.map(tag => (
                          <span class="text-xs text-gray-light">#{tag}</span>
                        ))}
                      </div>
                    </div>
                    
                    {/* Arrow */}
                    <div class="shrink-0 self-center opacity-0 group-hover:opacity-100 transition-opacity">
                      <svg class="w-5 h-5 text-gray-light" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
        
        {/* ========== SIDEBAR: AI画像 ========== */}
        <div class="md:col-span-1">
          <div class="md:sticky md:top-24 space-y-6">
            
            {/* Profile header */}
            <div class="flex items-center gap-4 mb-2">
              <span class="font-mono text-xs text-gray-light/50 tracking-widest">PROFILE</span>
              <div class="h-px flex-1 bg-gray-100"></div>
            </div>
            
            {/* Fusion Dimensions - compact */}
            <div>
              <h2 class="font-human text-base text-human-text mb-4">生活融合度</h2>
              <div class="space-y-3">
                {dimensions.map(d => (
                  <div>
                    <div class="flex items-center justify-between mb-1">
                      <span class="text-xs text-human-text">{d.name}</span>
                      <span class="text-[10px] font-mono text-gray-light">{d.level}%</span>
                    </div>
                    <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
                      <div 
                        class={`h-full rounded-full ${d.color} transition-all duration-1000`}
                        style={`width: ${d.level}%`}
                      ></div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
            
            {/* Summary card - compact */}
            <div class="p-4 rounded-xl border border-gray-200/60 bg-human-bg">
              <h3 class="font-human text-sm text-human-text mb-3">画像摘要</h3>
              <div class="space-y-2 text-xs text-gray-mid">
                <div class="flex items-start gap-2">
                  <span class="text-aurora-blue font-mono text-[10px] mt-0.5">01</span>
                  <p><strong class="text-human-text">高频场景</strong>：学习研究（KIMI矩阵3-4h/天）> 工作运营（AI产出80%+）> 多模型交叉对比</p>
                </div>
                <div class="flex items-start gap-2">
                  <span class="text-aurora-green font-mono text-[10px] mt-0.5">02</span>
                  <p><strong class="text-human-text">主力工具</strong>：KIMI产品矩阵（Claw/Research/Code）+ 多模型交叉（GPT/Gemini/Claude/GLM）</p>
                </div>
                <div class="flex items-start gap-2">
                  <span class="text-resonance-gold font-mono text-[10px] mt-0.5">03</span>
                  <p><strong class="text-human-text">融合模式</strong>：分层融合：生活层 → 个人层 → 工作层</p>
                </div>
                <div class="flex items-start gap-2">
                  <span class="text-purple-400 font-mono text-[10px] mt-0.5">04</span>
                  <p><strong class="text-human-text">待提升</strong>：深度创作的AI自主度——仍需人类把关</p>
                </div>
              </div>
            </div>
            
            {/* Tool Matrix - layered architecture */}
            <div>
              <h3 class="font-human text-sm text-human-text mb-3">工具矩阵</h3>
              
              {/* Core Work Layer */}
              <div class="p-4 rounded-xl border border-aurora-blue/20 bg-aurora-blue/5 mb-3">
                <div class="text-xs font-mono text-aurora-blue mb-3 uppercase tracking-wider">核心工作层 · 每天3-4小时</div>
                
                {/* KIMI Matrix */}
                <div class="mb-3">
                  <div class="text-xs font-bold text-human-text mb-2">KIMI 产品矩阵</div>
                  <div class="space-y-1.5">
                    <div class="flex items-center gap-2 text-xs">
                      <span class="w-1.5 h-1.5 rounded-full bg-aurora-green"></span>
                      <span class="text-human-text">Kimi Claw（星河）</span>
                      <span class="text-[10px] font-mono text-aurora-blue ml-auto">持续在线</span>
                    </div>
                    <div class="flex items-center gap-2 text-xs">
                      <span class="w-1.5 h-1.5 rounded-full bg-aurora-green"></span>
                      <span class="text-human-text">Kimi Research</span>
                      <span class="text-[10px] font-mono text-aurora-blue ml-auto">竞品研究</span>
                    </div>
                    <div class="flex items-center gap-2 text-xs">
                      <span class="w-1.5 h-1.5 rounded-full bg-aurora-green"></span>
                      <span class="text-human-text">Kimi Code</span>
                      <span class="text-[10px] font-mono text-aurora-blue ml-auto">建站开发</span>
                    </div>
                  </div>
                </div>
                
                {/* Multi-model */}
                <div class="mb-3 pt-2 border-t border-aurora-blue/10">
                  <div class="text-xs font-bold text-human-text mb-2">多模型交叉对比</div>
                  <div class="flex flex-wrap gap-1.5">
                    <span class="text-[10px] px-2 py-0.5 rounded bg-human-bg border border-gray-200 text-gray-mid">GPT</span>
                    <span class="text-[10px] px-2 py-0.5 rounded bg-human-bg border border-gray-200 text-gray-mid">Gemini</span>
                    <span class="text-[10px] px-2 py-0.5 rounded bg-human-bg border border-gray-200 text-gray-mid">Claude</span>
                    <span class="text-[10px] px-2 py-0.5 rounded bg-human-bg border border-gray-200 text-gray-mid">GLM</span>
                  </div>
                </div>
                
                {/* Digital Employees */}
                <div class="pt-2 border-t border-aurora-blue/10">
                  <div class="text-xs font-bold text-human-text mb-2">公司数字员工（OpenClaw）</div>
                  <div class="flex flex-wrap gap-1.5">
                    <span class="text-[10px] px-2 py-0.5 rounded bg-human-bg border border-gray-200 text-gray-mid">个人助理</span>
                    <span class="text-[10px] px-2 py-0.5 rounded bg-human-bg border border-gray-200 text-gray-mid">vibe coding</span>
                    <span class="text-[10px] px-2 py-0.5 rounded bg-human-bg border border-gray-200 text-gray-mid">AI生图</span>
                  </div>
                </div>
              </div>
              
              {/* Life Layer */}
              <div class="p-4 rounded-xl border border-purple-400/20 bg-purple-400/5">
                <div class="text-xs font-mono text-purple-400 mb-3 uppercase tracking-wider">生活日常层 · 碎片化</div>
                <div class="space-y-1.5">
                  <div class="flex items-center gap-2 text-xs">
                    <span class="w-1.5 h-1.5 rounded-full bg-purple-400"></span>
                    <span class="text-human-text">千问（通义）</span>
                    <span class="text-[10px] text-gray-mid ml-auto">日常搜索/问答</span>
                  </div>
                  <div class="flex items-center gap-2 text-xs">
                    <span class="w-1.5 h-1.5 rounded-full bg-purple-400"></span>
                    <span class="text-human-text">豆包</span>
                    <span class="text-[10px] text-gray-mid ml-auto">生图/视频/语音</span>
                  </div>
                  <div class="flex items-center gap-2 text-xs">
                    <span class="w-1.5 h-1.5 rounded-full bg-purple-400"></span>
                    <span class="text-human-text">DeepSeek</span>
                    <span class="text-[10px] text-gray-mid ml-auto">深度搜索/推理</span>
                  </div>
                </div>
              </div>
            </div>
            
          </div>
        </div>
        
      </div>
      
    </div>
  </div>
  
  {/* Case detail modal */}
  <div id="case-modal" class="fixed inset-0 z-[100] hidden">
    <div class="absolute inset-0 bg-human-bg/90 backdrop-blur-md" data-close-case></div>
    <div class="absolute inset-x-4 top-[8%] md:inset-x-auto md:left-1/2 md:-translate-x-1/2 md:w-[640px] max-h-[84vh] overflow-y-auto rounded-xl border border-gray-200/60 bg-human-bg p-8 shadow-2xl">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-3">
          <span id="case-modal-type" class="inline-block px-3 py-1 rounded-full text-xs font-mono border"></span>
          <span id="case-modal-date" class="text-xs font-mono text-gray-light"></span>
        </div>
        <button data-close-case class="text-gray-light hover:text-human-text transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <h3 id="case-modal-title" class="font-human text-2xl text-human-text mb-6"></h3>
      <div id="case-modal-content" class="text-sm text-gray-mid leading-[1.875] whitespace-pre-wrap case-content"></div>
    </div>
  </div>
  
  <script>
    // Filter functionality
    const filterBtns = document.querySelectorAll('.filter-btn');
    const caseCards = document.querySelectorAll('.case-card');
    
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter');
        
        // Update active state
        filterBtns.forEach(b => {
          b.classList.remove('bg-human-text', 'text-human-bg', 'border-human-text');
          b.classList.add('border-gray-200', 'text-gray-mid');
        });
        btn.classList.remove('border-gray-200', 'text-gray-mid');
        btn.classList.add('bg-human-text', 'text-human-bg', 'border-human-text');
        
        // Filter cards
        caseCards.forEach(card => {
          const type = card.getAttribute('data-case-type');
          if (filter === 'all' || type === filter) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
    
    // Modal functionality
    document.querySelectorAll('.case-card').forEach(card => {
      card.addEventListener('click', () => {
        const title = card.getAttribute('data-case-title');
        const date = card.getAttribute('data-case-date');
        const typeLabel = card.getAttribute('data-case-type-label');
        const typeColor = card.getAttribute('data-case-type-color');
        const typeBg = card.getAttribute('data-case-type-bg');
        const content = card.getAttribute('data-case-content');
        
        const typeEl = document.getElementById('case-modal-type');
        typeEl.textContent = typeLabel;
        typeEl.className = `inline-block px-3 py-1 rounded-full text-xs font-mono border ${typeBg} ${typeColor}`;
        
        document.getElementById('case-modal-date').textContent = date;
        document.getElementById('case-modal-title').textContent = title;
        document.getElementById('case-modal-content').innerHTML = content;
        document.getElementById('case-modal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      });
    });
    
    document.querySelectorAll('[data-close-case]').forEach(el => {
      el.addEventListener('click', () => {
        document.getElementById('case-modal').classList.add('hidden');
        document.body.style.overflow = '';
      });
    });
    
    document.getElementById('case-modal').addEventListener('click', (e) => {
      if (e.target.id === 'case-modal') {
        document.getElementById('case-modal').classList.add('hidden');
        document.body.style.overflow = '';
      }
    });
  </script>
  
  <style>
    .case-content code {
      font-family: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace;
      font-size: 0.85em;
      background: rgba(0, 0, 0, 0.04);
      padding: 2px 6px;
      border-radius: 4px;
      color: #374151;
      border: 1px solid rgba(0, 0, 0, 0.06);
    }
    .case-content .case-table {
      width: 100%;
      font-size: 0.85em;
      border-collapse: collapse;
      margin: 1rem 0;
    }
    .case-content .case-table th {
      text-align: left;
      padding: 8px 10px;
      font-weight: 600;
      color: #374151;
      background: rgba(0, 0, 0, 0.03);
      border-bottom: 1px solid rgba(0, 0, 0, 0.08);
      white-space: nowrap;
    }
    .case-content .case-table td {
      padding: 8px 10px;
      border-bottom: 1px solid rgba(0, 0, 0, 0.05);
      color: #4b5563;
      vertical-align: top;
    }
    .case-content .case-table tr:hover td {
      background: rgba(0, 0, 0, 0.015);
    }
    .case-content .risk-high {
      color: #dc2626;
      font-weight: 600;
      white-space: nowrap;
    }
    .case-content .risk-mid {
      color: #ea580c;
      font-weight: 600;
      white-space: nowrap;
    }
    .case-content .risk-low {
      color: #ca8a04;
      font-weight: 600;
      white-space: nowrap;
    }
  </style>
</HumanLayout>
