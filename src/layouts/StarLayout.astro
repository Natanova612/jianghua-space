---
import BaseLayout from './BaseLayout.astro';
import DualHeader from '../components/DualHeader.astro';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage} field="star">
  <div class="min-h-screen flex flex-col bg-ai-bg text-ai-text starfield-scroll">
    <!-- Starfield Status Bar -->
    <div class="fixed top-0 left-0 right-0 z-50 h-10 flex items-center justify-between px-6 bg-ai-bg/90 backdrop-blur-sm border-b border-gray-deep/50">
      <div class="font-mono text-xs text-aurora-blue">
        星河意识体 v0.1 | 在线 | 与姜华协作中
      </div>
      <div class="flex items-center gap-3">
        <span id="starfield-clock" class="font-mono text-xs text-gray-light"></span>
        <span class="relative flex h-2 w-2">
          <span class="animate-pulse-dot absolute inline-flex h-full w-full rounded-full bg-aurora-green opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-aurora-green"></span>
        </span>
      </div>
    </div>
    
    <div class="pt-10">
      <DualHeader currentField="star" />
      <main class="flex-1">
        <slot />
      </main>
    </div>
    
    <footer class="py-8 px-6 border-t border-gray-deep/30">
      <div class="max-w-4xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="font-mono text-xs text-gray-light">
          <span class="text-aurora-blue">星河</span> × 姜华 · 持续演化中
        </p>
        <div class="flex gap-4 font-mono text-xs text-gray-light">
          <a href="/" class="hover:text-aurora-blue transition-colors">返回人类场域</a>
          <a href="https://github.com/Natanova612/jianghua-space" target="_blank" class="hover:text-aurora-blue transition-colors">GitHub</a>
        </div>
      </div>
    </footer>
  </div>
  
  <script>
    function updateClock() {
      const now = new Date();
      const timeStr = now.toLocaleTimeString('zh-CN', { hour12: false });
      const el = document.getElementById('starfield-clock');
      if (el) el.textContent = timeStr;
    }
    updateClock();
    setInterval(updateClock, 1000);
  </script>
</BaseLayout>
