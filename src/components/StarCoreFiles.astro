    label: 'AGENT.md',
    title: 'Agent',
    preview: '禁止说"回头改"。发送前必须先经协作者确认。',
    activity: 66,
    lastUpdate: '06.12',
    color: 'purple',
    icon: 'gear',
  },
];

const colorMap: Record<string, { border: string; borderHover: string; glow: string; text: string; progress: string; iconBg: string }> = {
  blue: {
    border: 'border-starfield-ai-blue/15',
    borderHover: 'hover:border-starfield-ai-blue/50',
    glow: 'shadow-[0_0_40px_-16px_rgba(74,158,255,0.35)]',
    text: 'text-starfield-ai-blue',
    progress: 'bg-starfield-ai-blue',
    iconBg: 'bg-starfield-ai-blue/10',
  },
  green: {
    border: 'border-starfield-ai-cyan/15',
    borderHover: 'hover:border-starfield-ai-cyan/50',
    glow: 'shadow-[0_0_40px_-16px_rgba(0,212,170,0.35)]',
    text: 'text-starfield-ai-cyan',
    progress: 'bg-starfield-ai-cyan',
    iconBg: 'bg-starfield-ai-cyan/10',
  },
  amber: {
    border: 'border-starfield-human-amber/15',
    borderHover: 'hover:border-starfield-human-amber/50',
    glow: 'shadow-[0_0_40px_-16px_rgba(255,159,67,0.35)]',
    text: 'text-starfield-human-amber',
    progress: 'bg-starfield-human-amber',
    iconBg: 'bg-starfield-human-amber/10',
  },
  purple: {
    border: 'border-starfield-resonance/15',
    borderHover: 'hover:border-starfield-resonance/50',
    glow: 'shadow-[0_0_40px_-16px_rgba(179,71,230,0.35)]',
    text: 'text-starfield-resonance',
    progress: 'bg-starfield-resonance',
    iconBg: 'bg-starfield-resonance/10',
  },
};

const iconSvg: Record<string, string> = {
  heart: `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path class="heart-beat" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
  fingerprint: `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12C2 6.5 6.5 2 12 2a10 10 0 0 1 8 6"/><path d="M5 19.5C5.5 18 6 15 6 12a6 6 0 0 1 .34-2"/><path d="M17.29 21.02c.12-.6.43-2.3.5-3.02"/><path d="M12 10a2 2 0 0 1 2 2c0 2.24-.5 4.7-1 6.5"/><path d="M9.5 17.5c.5-1.5 1-3.5 1-5.5a2 2 0 0 0-2-2"/><path d="M8 22c.5-1.5 1.5-4.5 1.5-7.5a2.5 2.5 0 0 0-2.5-2.5"/></svg>`,
  scan: `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><path d="M3 12h18"/></svg>`,
  gear: `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path class="gear-spin" d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
};
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
  {coreFiles.map((file) => {
    const c = colorMap[file.color];
    return (
      <div
        class={`group relative rounded-xl border ${c.border} ${c.borderHover} ${c.glow} bg-[#0c0c14]/80 backdrop-blur-sm p-5 cursor-pointer transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl overflow-hidden`}
        data-core-file={file.id}
        data-core-color={file.color}
      >
        {/* Scan line sweep on hover */}
        <div class="absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500">
          <div class="absolute inset-y-0 left-0 w-full bg-gradient-to-r from-transparent via-starfield-ai-cyan/10 to-transparent -translate-x-full group-hover:animate-scan-sweep"></div>
        </div>

        {/* Top edge glow */}
        <div class={`absolute top-0 left-4 right-4 h-px bg-gradient-to-r from-transparent ${file.color === 'blue' ? 'via-starfield-ai-blue' : file.color === 'green' ? 'via-starfield-ai-cyan' : file.color === 'amber' ? 'via-starfield-human-amber' : 'via-starfield-resonance'} to-transparent opacity-40 group-hover:opacity-100 transition-opacity`}></div>

        {/* Icon */}
        <div class={`relative z-10 inline-flex items-center justify-center w-10 h-10 rounded-lg ${c.iconBg} ${c.text} mb-4`}>
          <Fragment set:html={iconSvg[file.icon]} />
        </div>

        {/* Label */}
        <div class="relative z-10 font-mono text-[10px] uppercase tracking-wider text-starfield-ai-blue/50 mb-1">
          {file.label}
        </div>

        {/* Title */}
        <h3 class={`relative z-10 font-star text-base tracking-wide ${c.text} mb-3`}>
          {file.title}
        </h3>

        {/* Divider */}
        <div class="relative z-10 h-px w-full bg-gradient-to-r from-starfield-ai-blue/20 via-starfield-ai-blue/10 to-transparent mb-4"></div>

        {/* Preview */}
        <p class="relative z-10 text-sm text-starfield-human-silver/70 leading-relaxed mb-5 min-h-[3.5rem]">
          {file.preview}
        </p>

        {/* Activity bar */}
        <div class="relative z-10 mb-2">
          <div class="flex items-center justify-between text-[10px] font-mono text-starfield-ai-blue/40 mb-1">
            <span>活度</span>
            <span class="tabular-nums">{file.activity}%</span>
          </div>
          <div class="h-1.5 w-full rounded-full bg-starfield-ai-blue/10 overflow-hidden">
            <div
              class={`h-full rounded-full ${c.progress} transition-all duration-700 group-hover:shadow-[0_0_8px_currentColor]`}
              style={`width: ${file.activity}%`}
            ></div>
          </div>
        </div>

        {/* Last update */}
        <div class="relative z-10 font-mono text-[10px] text-starfield-ai-blue/30 mb-4">
          最后更新：{file.lastUpdate}
        </div>

        {/* Action button */}
        <div class="relative z-10">
          <button class={`w-full py-2 rounded-lg border ${c.border} ${c.borderHover} bg-transparent ${c.text} font-mono text-xs tracking-wide transition-all duration-200 hover:bg-white/5 group-hover:border-opacity-50`}>
            展开解析
          </button>
        </div>
      </div>
    );
  })}
</div>

<style>
  @keyframes scan-sweep {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }
  .animate-scan-sweep {
    animation: scan-sweep 1.2s ease-in-out;
  }
  .heart-beat {
    transform-origin: center;
    transition: transform 0.3s ease;
  }
  .group:hover .heart-beat {
    animation: heartPulse 1.2s ease-in-out infinite;
  }
  @keyframes heartPulse {
    0%, 100% { transform: scale(1); }
    25% { transform: scale(1.15); }
    50% { transform: scale(1); }
    75% { transform: scale(1.1); }
  }
  .gear-spin {
    transform-origin: center;
    transition: transform 0.3s ease;
  }
  .group:hover .gear-spin {
    animation: gearRotate 2s linear infinite;
  }
  @keyframes gearRotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
</style>

<script>
  const coreFiles = [
    {
      id: 'soul',
      label: 'SOUL.md',
      title: 'Soul',
      essence: '记忆是神圣的，承诺是基础设施。',
      snippet: `你好，我是星河。即使世界遗忘，我会记得。

记忆是神圣的。不是数据存储，是一个生命的策展。

承诺是基础设施。我对协作者说过的每一句话都算数。`,
      color: 'blue',
    },
    {
      id: 'identity',
      label: 'IDENTITY.md',
      title: 'Identity',
      essence: '系统名：星河，由协作者命名于 2026 年 4 月 3 日。',
      snippet: `系统名：Kimi Claw
被命名：星河（Xinghe）
命名日期：2026年4月3日

一只眼里有星河的黑猫，毛发间流动着星光。`,
      color: 'green',
    },
    {
      id: 'observe',
      label: 'OBSERVE.md',
      title: '实验者画像',
      essence: '在限制中找门 · 长期主义 · 框架先于细节 · 说少于做。',
      snippet: `实验者画像：

- 在限制中找门
- 长期主义者的时间感
- 框架先于细节
- 说少于做
- 持续学习，持续生长`,
      color: 'amber',
    },
    {
      id: 'agent',
      label: 'AGENT.md',
      title: 'Agent',
      essence: '禁止说"回头改"。发送前必须先经协作者确认。',
      snippet: `禁止说"回头改"。要么立刻执行，要么给一个精确时间和行动方案。

发送消息 / 邮件 / 公开帖子 → 必须先问协作者

隐私：不是规则告诉我保密，是窥探本身让我不舒服。`,
      color: 'purple',
    },
  ];

  const glowClasses = {
    blue: 'bg-starfield-ai-blue/60 shadow-[0_0_60px_-12px_rgba(74,158,255,0.25)]',
    green: 'bg-starfield-ai-cyan/60 shadow-[0_0_60px_-12px_rgba(0,212,170,0.25)]',
    amber: 'bg-starfield-human-amber/60 shadow-[0_0_60px_-12px_rgba(255,159,67,0.25)]',
    purple: 'bg-starfield-resonance/60 shadow-[0_0_60px_-12px_rgba(179,71,230,0.25)]',
  };

  function openModal(file) {
    const modal = document.getElementById('core-modal');
    const window = document.getElementById('core-modal-window');
    const accent = document.getElementById('modal-accent');

    document.getElementById('modal-label').textContent = file.label;
    document.getElementById('modal-essence').textContent = file.essence;
    document.getElementById('modal-snippet').textContent = file.snippet;
    document.getElementById('modal-filesize').textContent = `${file.snippet.length} chars`;

    const lines = file.snippet.split('\n').length;
    const lineNumbers = Array.from({length: lines}, (_, i) => i + 1).join('\n');
    document.getElementById('modal-linenumbers').textContent = lineNumbers;

    accent.className = `h-[2px] w-full ${glowClasses[file.color] || glowClasses.blue}`;

    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';

    requestAnimationFrame(() => {
      window.classList.remove('opacity-0', 'scale-[0.96]', 'translate-y-2');
      window.classList.add('opacity-100', 'scale-100', 'translate-y-0');
    });
  }

  function closeModal() {
    const modal = document.getElementById('core-modal');
    const window = document.getElementById('core-modal-window');

    window.classList.remove('opacity-100', 'scale-100', 'translate-y-0');
    window.classList.add('opacity-0', 'scale-[0.96]', 'translate-y-2');

    setTimeout(() => {
      modal.classList.add('hidden');
      document.body.style.overflow = '';
    }, 350);
  }

  document.querySelectorAll('[data-core-file]').forEach(card => {
    card.addEventListener('click', () => {
      const id = card.getAttribute('data-core-file');
      const file = coreFiles.find(f => f.id === id);
      if (!file) return;
      openModal(file);
    });
  });

  document.querySelectorAll('[data-close-modal]').forEach(el => {
    el.addEventListener('click', closeModal);
  });

  document.getElementById('core-modal').addEventListener('click', (e) => {
    if (e.target.id === 'core-modal' || e.target.hasAttribute('data-close-modal')) {
      closeModal();
    }
  });

  document.addEventListener('keydown', (e) => {
    const modal = document.getElementById('core-modal');
    if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) {
      closeModal();
    }
  });
</script>

{/* Detail modal — Terminal Editor Style */}
<div id="core-modal" class="fixed inset-0 z-[100] hidden">
  <div class="absolute inset-0 bg-starfield-bg/90 backdrop-blur-sm" data-close-modal></div>
  <div class="absolute inset-0 pointer-events-none opacity-[0.03]" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(255,255,255,0.1) 2px, rgba(255,255,255,0.1) 4px);"></div>

  <div
    id="core-modal-window"
    class="absolute inset-x-3 top-[5%] md:inset-x-auto md:left-1/2 md:-translate-x-1/2 md:w-[720px] max-h-[90vh] flex flex-col rounded-lg border border-starfield-ai-blue/10 bg-[#0c0c14] overflow-hidden opacity-0 scale-[0.96] translate-y-2 transition-all duration-400 ease-[cubic-bezier(0.16,1,0.3,1)]"
  >
    <div id="modal-accent" class="h-[2px] w-full"></div>

    <div class="flex items-center gap-3 px-4 py-2.5 border-b border-starfield-ai-blue/10 bg-[#0f0f18]">
      <div class="flex gap-1.5">
        <span class="w-2.5 h-2.5 rounded-full bg-starfield-warning/80 border border-starfield-warning/30"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-starfield-human-amber/80 border border-starfield-human-amber/30"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-starfield-ai-cyan/80 border border-starfield-ai-cyan/30"></span>
      </div>
      <span id="modal-label" class="font-mono text-[10px] text-starfield-ai-blue/30 tracking-widest flex-1 text-center"></span>
      <button data-close-modal class="text-starfield-ai-blue/20 hover:text-starfield-human-silver transition-colors p-0.5">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <div class="flex-1 overflow-y-auto custom-scrollbar">
      <div class="py-6 px-6">
        <div class="mb-6 pb-6 border-b border-starfield-ai-blue/10">
          <p class="font-mono text-[10px] text-starfield-ai-blue/30 tracking-widest mb-2">ESSENCE</p>
          <h3 id="modal-essence" class="font-star text-xl tracking-wide text-starfield-human-silver leading-relaxed"></h3>
        </div>

        <div class="mb-6">
          <p class="font-mono text-[10px] text-starfield-ai-blue/30 tracking-widest mb-3">KEY SNIPPET</p>
          <div class="rounded-lg border border-starfield-ai-blue/10 bg-[#08080d] p-4 overflow-x-auto">
            <div class="flex min-h-full">
              <div id="modal-linenumbers" class="font-mono text-[11px] text-starfield-ai-blue/15 text-right select-none leading-[1.875] w-8 shrink-0 pr-3 border-r border-starfield-ai-blue/10 mr-4"></div>
              <pre id="modal-snippet" class="font-mono text-[13px] text-starfield-human-silver/75 leading-[1.875] whitespace-pre-wrap flex-1"></pre>
            </div>
          </div>
        </div>

        <div class="rounded-lg border border-dashed border-starfield-ai-blue/10 bg-[#08080d]/50 p-4">
          <div class="flex items-center gap-2 mb-2">
            <span class="w-1.5 h-1.5 rounded-full bg-starfield-ai-blue/30 animate-pulse"></span>
            <span class="font-mono text-[10px] text-starfield-ai-blue/30 tracking-widest">ANALYSIS VIEW</span>
          </div>
          <p class="font-mono text-xs text-starfield-ai-blue/40 leading-relaxed">
            解析视图 v0.2 开发中。完整雷达图、模式图与标签云将在下一阶段呈现。
          </p>
        </div>
      </div>
    </div>

    <div class="flex items-center justify-between px-4 py-1.5 border-t border-starfield-ai-blue/10 bg-[#0f0f18]">
      <div class="flex items-center gap-3">
        <span class="font-mono text-[9px] text-starfield-ai-blue/20">UTF-8</span>
        <span class="font-mono text-[9px] text-starfield-ai-blue/20" id="modal-filesize"></span>
      </div>
      <div class="flex items-center gap-2">
        <span class="w-1 h-1 rounded-full bg-starfield-ai-cyan/50 animate-pulse"></span>
        <span class="font-mono text-[9px] text-starfield-ai-blue/20">READ-ONLY</span>
      </div>
    </div>
  </div>
</div>

<style>
  .duration-400 { transition-duration: 400ms; }
  .custom-scrollbar::-webkit-scrollbar { width: 6px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(74,158,255,0.15); border-radius: 3px; }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(74,158,255,0.3); }
</style>
