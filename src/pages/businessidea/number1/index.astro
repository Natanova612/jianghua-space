---
// AI 店长商业计划展示站点
// Route: /businessidea/number1/
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI 店长 —— 让每家民宿都有一位智能管家</title>
  <meta name="description" content="AI店长：为中小民宿打造的AI经营管理Agent，解决用不起、不会用、用不好的三不困境。">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Noto+Sans+SC:wght@400;500;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'deep-night': '#0a0f1c',
            'midnight': '#0f172a',
            'warm-amber': '#f59e0b',
            'soft-coral': '#f87171',
            'mint-green': '#34d399',
            'star-blue': '#60a5fa',
          },
          fontFamily: {
            'sans': ['Noto Sans SC', 'sans-serif'],
            'mono': ['JetBrains Mono', 'monospace'],
            'serif': ['Playfair Display', 'serif'],
          }
        }
      }
    }
  </script>
  <style>
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Noto Sans SC', sans-serif;
      background: #0a0f1c;
      color: #e2e8f0;
    }
    .glass {
      background: rgba(255,255,255,0.03);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,0.06);
    }
    .glow-amber {
      box-shadow: 0 0 40px -10px rgba(245,158,11,0.15);
    }
    .glow-coral {
      box-shadow: 0 0 40px -10px rgba(248,113,113,0.15);
    }
    .text-gradient {
      background: linear-gradient(135deg, #f59e0b 0%, #f87171 50%, #60a5fa 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .section-divider {
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(245,158,11,0.3), rgba(96,165,250,0.3), transparent);
    }
    .nav-link.active {
      color: #f59e0b;
    }
    .nav-link::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 0;
      width: 0;
      height: 2px;
      background: #f59e0b;
      transition: width 0.3s;
    }
    .nav-link:hover::after,
    .nav-link.active::after {
      width: 100%;
    }
  </style>
</head>

<body class="antialiased">

  {/* Navigation */}
  <nav class="fixed top-0 left-0 right-0 z-50 glass">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="#hero" class="font-serif text-xl font-bold text-gradient">AI 店长</a>
      <div class="hidden md:flex items-center gap-8 text-sm">
        <a href="#problem" class="nav-link relative text-slate-400 hover:text-warm-amber transition-colors">市场空白</a>
        <a href="#competitor" class="nav-link relative text-slate-400 hover:text-warm-amber transition-colors">竞品分析</a>
        <a href="#solution" class="nav-link relative text-slate-400 hover:text-warm-amber transition-colors">解决方案</a>
        <a href="#demo" class="nav-link relative text-slate-400 hover:text-warm-amber transition-colors">产品演示</a>
        <a href="#business" class="nav-link relative text-slate-400 hover:text-warm-amber transition-colors">商业模式</a>
        <a href="#contact" class="nav-link relative text-slate-400 hover:text-warm-amber transition-colors">联系我们</a>
      </div>
    </div>
  </nav>

  {/* ===== HERO ===== */}
  <section id="hero" class="min-h-screen flex items-center justify-center relative overflow-hidden pt-20">
    {/* Background ambient glow */}
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-warm-amber/5 rounded-full blur-[100px]"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-star-blue/5 rounded-full blur-[100px]"></div>
    
    <div class="max-w-4xl mx-auto px-6 text-center relative z-10">
      <p class="font-mono text-xs text-warm-amber/70 tracking-[0.3em] uppercase mb-6">Business Plan 2026</p>
      <h1 class="font-serif text-5xl md:text-7xl font-bold leading-tight mb-6">
        让每家民宿<br>
        <span class="text-gradient">都有一位智能管家</span>
      </h1>
      <p class="text-lg md:text-xl text-slate-400 max-w-2xl mx-auto mb-4 leading-relaxed">
        AI 店长是为中小民宿打造的 AI 经营管理 Agent。<br class="hidden md:block">
        解决<strong class="text-warm-amber">用不起、不会用、用不好</strong>的三不困境。
      </p>
      <p class="text-sm text-slate-500 mb-12 font-mono">
        结构性市场空白 · 18-24 个月黄金窗口期 · 自研大模型 + 多模态融合
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#solution" class="group relative px-8 py-3.5 bg-warm-amber text-deep-night font-bold rounded-full shadow-[0_4px_20px_-4px_rgba(245,158,11,0.5)] hover:shadow-[0_8px_30px_-4px_rgba(245,158,11,0.7)] hover:-translate-y-0.5 transition-all duration-300">
          <span class="relative z-10">了解 AI 店长</span>
          <span class="absolute inset-0 rounded-full bg-white/20 opacity-0 group-hover:opacity-100 transition-opacity"></span>
        </a>
        <a href="#contact" class="group px-8 py-3.5 border-2 border-slate-500 text-slate-300 rounded-full hover:border-warm-amber hover:text-warm-amber hover:shadow-[0_4px_20px_-4px_rgba(245,158,11,0.2)] hover:-translate-y-0.5 transition-all duration-300 font-medium">
          成为合伙人 / 投资人
        </a>
      </div>
    </div>
    
    {/* Scroll hint */}
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-slate-600">
      <span class="text-xs font-mono">SCROLL</span>
      <div class="w-px h-8 bg-gradient-to-b from-slate-600 to-transparent"></div>
    </div>
  </section>

  <div class="section-divider max-w-4xl mx-auto"></div>

  {/* ===== PROBLEM ===== */}
  <section id="problem" class="py-24 md:py-32">
    <div class="max-w-5xl mx-auto px-6">
      <p class="font-mono text-xs text-warm-amber/70 tracking-[0.3em] uppercase mb-4">THE PROBLEM</p>
      <h2 class="font-serif text-3xl md:text-4xl font-bold mb-4">80% 的中小民宿，<br>正在被数字化遗忘</h2>
      <p class="text-slate-400 max-w-2xl mb-16">
        中国民宿行业超过 80% 为单体经营、客房数少于 20 间的微型物业。这一长尾市场的 AI 渗透率不足 5%，构成巨大的结构性空白。
      </p>
      
      <div class="grid md:grid-cols-3 gap-6">
        <div class="glass rounded-2xl p-8 glow-amber">
          <div class="text-4xl mb-4">💸</div>
          <h3 class="font-serif text-xl font-bold text-warm-amber mb-2">用不起</h3>
          <p class="text-sm text-slate-400 leading-relaxed">
            国际竞品 $100-500/月，相当于中小民宿 1.5-2.5% 的营收。国内竞品高级功能付费后性价比低，免费版功能鸡肋。
          </p>
        </div>
        <div class="glass rounded-2xl p-8 glow-coral">
          <div class="text-4xl mb-4">🤯</div>
          <h3 class="font-serif text-xl font-bold text-soft-coral mb-2">不会用</h3>
          <p class="text-sm text-slate-400 leading-relaxed">
            产品复杂度高，需要专业 IT 人员配置。缺乏中文本地化支持，实施培训不足，上手周期长。
          </p>
        </div>
        <div class="glass rounded-2xl p-8">
          <div class="text-4xl mb-4">😤</div>
          <h3 class="font-serif text-xl font-bold text-mint-green mb-2">用不好</h3>
          <p class="text-sm text-slate-400 leading-relaxed">
            AI 效果不达预期，自动化率虚高。将"自动回复"与"自动解决"混为一谈，实际运营中频繁转人工。
          </p>
        </div>
      </div>
      
      {/* Key data */}
      <div class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="font-serif text-3xl font-bold text-warm-amber">80%+</div>
          <div class="text-xs text-slate-500 mt-1">单体经营占比</div>
        </div>
        <div class="text-center">
          <div class="font-serif text-3xl font-bold text-soft-coral">&lt;5%</div>
          <div class="text-xs text-slate-500 mt-1">AI 渗透率</div>
        </div>
        <div class="text-center">
          <div class="font-serif text-3xl font-bold text-star-blue">20万+</div>
          <div class="text-xs text-slate-500 mt-1">民宿市场主体</div>
        </div>
        <div class="text-center">
          <div class="font-serif text-3xl font-bold text-mint-green">0</div>
          <div class="text-xs text-slate-500 mt-1">国际竞品布局中国</div>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider max-w-4xl mx-auto"></div>

  {/* ===== PAIN STORY: A Day of B&B Owner ===== */}
  <section id="pain-story" class="py-24 md:py-32">
    <div class="max-w-5xl mx-auto px-6">
      <p class="font-mono text-xs text-warm-amber/70 tracking-[0.3em] uppercase mb-4">A DAY IN THE LIFE</p>
      <h2 class="font-serif text-3xl md:text-4xl font-bold mb-4">民宿老板的一天</h2>
      <p class="text-slate-400 max-w-2xl mb-16">
        从清晨到深夜，每一个运营节点都是一场战斗。旺季人手不够，淡季闲得发慌——这就是中小民宿经营者的日常。
      </p>
      
      {/* Timeline */}
      <div class="relative">
        {/* Center line */}
        <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-slate-700 md:-translate-x-px"></div>
        
        {/* 08:00 */}
        <div class="relative flex flex-col md:flex-row items-start mb-12">
          <div class="md:w-1/2 md:text-right md:pr-12 pl-12 md:pl-0">
            <div class="font-mono text-xs text-warm-amber mb-1">08:00</div>
            <h3 class="font-medium mb-2">查房 & 清洁排班</h3>
            <p class="text-sm text-slate-500">退房检查、安排清洁、确认布草更换。旺季时一个人要盯 10+ 间房。</p>
          </div>
          <div class="absolute left-4 md:left-1/2 top-1 w-3 h-3 rounded-full bg-slate-600 border-2 border-deep-night -translate-x-1/2"></div>
          <div class="md:w-1/2 md:pl-12 pl-12 mt-2 md:mt-0">
            <div class="flex items-center gap-2">
              <span class="text-xs text-slate-500">痛点强度</span>
              <div class="flex gap-1">
                <span class="w-6 h-2 rounded-full bg-warm-amber"></span>
                <span class="w-6 h-2 rounded-full bg-warm-amber"></span>
                <span class="w-6 h-2 rounded-full bg-warm-amber"></span>
                <span class="w-6 h-2 rounded-full bg-slate-700"></span>
                <span class="w-6 h-2 rounded-full bg-slate-700"></span>
              </div>
            </div>
          </div>
        </div>
        
        {/* 10:00 */}
        <div class="relative flex flex-col md:flex-row items-start mb-12">
          <div class="md:w-1/2 md:text-right md:pr-12 pl-12 md:pl-0 md:order-1 order-2 mt-2 md:mt-0">
            <div class="flex items-center gap-2 md:justify-end">
              <div class="flex gap-1">
                <span class="w-6 h-2 rounded-full bg-warm-amber"></span>
                <span class="w-6 h-2 rounded-full bg-warm-amber"></span>
                <span class="w-6 h-2 rounded-full bg-warm-amber"></span>
                <span class="w-6 h-2 rounded-full bg-warm-amber"></span>
                <span class="w-6 h-2 rounded-full bg-slate-700"></span>
              </div>
              <span class="text-xs text-slate-500">痛点强度</span>
            </div>
          </div>
          <div class="absolute left-4 md:left-1/2 top-1 w-3 h-3 rounded-full bg-soft-coral border-2 border-deep-night -translate-x-1/2"></div>
          <div class="md:w-1/2 md:pl-12 pl-12 md:order-2 order-1">
            <div class="font-mono text-xs text-soft-coral mb-1">10:00</div>
            <h3 class="font-medium mb-2">预订咨询轰炸 🔥</h3>
            <p class="text-sm text-slate-500">微信、OTA、电话同时响。"还有房吗？""能带宠物吗？""早餐几点？"——同样的问题每天要回答 30 遍。</p>
          </div>
        </div>
        
        {/* 14:00 */}
        <div class="relative flex flex-col md:flex-row items-start mb-12">
          <div class="md:w-1/2 md:text-right md:pr-12 pl-12 md:pl-0">
            <div class="font-mono text-xs text-warm-amber mb-1">14:00</div>
            <h3 class="font-medium mb-2">入住接待 & 问题处理</h3>
            <p class="text-sm text-slate-500">办入住、讲解设施、处理 WiFi 故障、空调不会用、找不到停车位……老板 = 前台 + 维修 + 导游。</p>
          </div>
          <div class="absolute left-4 md:left-1/2 top-1 w-3 h-3 rounded-full bg-soft-coral border-2 border-deep-night -translate-x-1/2"></div>
          <div class="md:w-1/2 md:pl-12 pl-12 mt-2 md:mt-0">
            <div class="flex items-center gap-2">
              <span class="text-xs text-slate-500">痛点强度</span>
              <div class="flex gap-1">
                <span class="w-6 h-2 rounded-full bg-warm-amber"></span>
                <span class="w-6 h-2 rounded-full bg-warm-amber"></span>
                <span class="w-6 h-2 rounded-full bg-warm-amber"></span>
                <span class="w-6 h-2 rounded-full bg-warm-amber"></span>
                <span class="w-6 h-2 rounded-full bg-slate-700"></span>
              </div>
            </div>
          </div>
        </div>
        
        {/* 18:00 */}
        <div class="relative flex flex-col md:flex-row items-start mb-12">
          <div class="md:w-1/2 md:text-right md:pr-12 pl-12 md:pl-0 md:order-1 order-2 mt-2 md:mt-0">
            <div class="flex items-center gap-2 md:justify-end">
              <div class="flex gap-1">
                <span class="w-6 h-2 rounded-full bg-warm-amber"></span>
                <span class="w-6 h-2 rounded-full bg-warm-amber"></span>
                <span class="w-6 h-2 rounded-full bg-warm-amber"></span>
                <span class="w-6 h-2 rounded-full bg-warm-amber"></span>
                <span class="w-6 h-2 rounded-full bg-warm-amber"></span>
              </div>
              <span class="text-xs text-slate-500">痛点强度</span>
            </div>
          </div>
          <div class="absolute left-4 md:left-1/2 top-1 w-3 h-3 rounded-full bg-red-500 border-2 border-deep-night -translate-x-1/2"></div>
          <div class="md:w-1/2 md:pl-12 pl-12 md:order-2 order-1">
            <div class="font-mono text-xs text-red-400 mb-1">18:00</div>
            <h3 class="font-medium mb-2">晚餐时间 = 加班时间 💥</h3>
            <p class="text-sm text-slate-500">刚想吃饭，客人说热水器坏了。处理完回来菜凉了。深夜还要回复明天的预订咨询——民宿没有下班时间。</p>
          </div>
        </div>
        
        {/* 23:00 */}
        <div class="relative flex flex-col md:flex-row items-start">
          <div class="md:w-1/2 md:text-right md:pr-12 pl-12 md:pl-0">
            <div class="font-mono text-xs text-star-blue mb-1">23:00</div>
            <h3 class="font-medium mb-2">终于可以躺下……</h3>
            <p class="text-sm text-slate-500">但手机还在震动。OTA 又来了一条差评提醒。明天要涨价还是降价？心里没底，只能猜。</p>
          </div>
          <div class="absolute left-4 md:left-1/2 top-1 w-3 h-3 rounded-full bg-slate-600 border-2 border-deep-night -translate-x-1/2"></div>
          <div class="md:w-1/2 md:pl-12 pl-12 mt-2 md:mt-0">
            <div class="flex items-center gap-2">
              <span class="text-xs text-slate-500">痛点强度</span>
              <div class="flex gap-1">
                <span class="w-6 h-2 rounded-full bg-warm-amber"></span>
                <span class="w-6 h-2 rounded-full bg-warm-amber"></span>
                <span class="w-6 h-2 rounded-full bg-slate-700"></span>
                <span class="w-6 h-2 rounded-full bg-slate-700"></span>
                <span class="w-6 h-2 rounded-full bg-slate-700"></span>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      {/* Summary card */}
      <div class="mt-16 glass rounded-2xl p-8 border-l-4 border-warm-amber">
        <p class="text-lg text-slate-300 leading-relaxed">
          这位老板不是特例。中国<strong class="text-warm-amber">20 万+</strong>中小民宿经营者中，<strong class="text-warm-amber">80%</strong>是单体经营、客房数少于 20 间，<strong class="text-warm-amber">没有专职前台、没有 IT 人员、没有运营团队</strong>——一个人就是一家公司。
        </p>
      </div>
    </div>
  </section>

  <div class="section-divider max-w-4xl mx-auto"></div>

  {/* ===== COMPETITOR ===== */}
  <section id="competitor" class="py-24 md:py-32">
    <div class="max-w-5xl mx-auto px-6">
      <p class="font-mono text-xs text-warm-amber/70 tracking-[0.3em] uppercase mb-4">COMPETITIVE LANDSCAPE</p>
      <h2 class="font-serif text-3xl md:text-4xl font-bold mb-4">国际市场技术领先但零布局中国<br>国内市场覆盖广但 AI 深度不足</h2>
      <p class="text-slate-400 max-w-2xl mb-16">
        深度剖析 12 家国内外竞品，揭示结构性市场空白与"AI 店长"的战略机遇。
      </p>
      
      {/* International vs Domestic */}
      <div class="grid md:grid-cols-2 gap-8 mb-16">
        <div class="glass rounded-2xl p-8">
          <h3 class="font-serif text-xl font-bold mb-6 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-star-blue"></span>
            国际市场：技术领先，数字通胀
          </h3>
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <span class="font-mono text-xs text-star-blue mt-1">01</span>
              <div>
                <p class="text-sm font-medium">自动化率宣称 80-97%，实际存疑</p>
                <p class="text-xs text-slate-500">Visito AI 97%、Runnr.ai 95%、Duve 80-97% —— 缺乏第三方审计，定义模糊</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="font-mono text-xs text-star-blue mt-1">02</span>
              <div>
                <p class="text-sm font-medium">全部 7 家国际竞品零布局中国</p>
                <p class="text-xs text-slate-500">合规周期 12-18 个月 + 技术适配 6-12 个月 + 生态重建 12-24 个月</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="font-mono text-xs text-star-blue mt-1">03</span>
              <div>
                <p class="text-sm font-medium">定价门槛高，中小民宿友好度低</p>
                <p class="text-xs text-slate-500">$99-599/月，年度预付订阅制，与中国企业付费习惯冲突</p>
              </div>
            </div>
          </div>
        </div>
        
        <div class="glass rounded-2xl p-8">
          <h3 class="font-serif text-xl font-bold mb-6 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full text-warm-amber" style="background:#f59e0b"></span>
            国内市场：PMS 强，AI 浅
          </h3>
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <span class="font-mono text-xs text-warm-amber mt-1">01</span>
              <div>
                <p class="text-sm font-medium">大模型应用浅层化</p>
                <p class="text-xs text-slate-500">多基于通用 API 简单封装，未进行酒店垂直领域深度训练</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="font-mono text-xs text-warm-amber mt-1">02</span>
              <div>
                <p class="text-sm font-medium">多模态交互完全缺失</p>
                <p class="text-xs text-slate-500">无一具备 Voice AI 或视觉 AI 能力，功能堆砌而非深耕</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="font-mono text-xs text-warm-amber mt-1">03</span>
              <div>
                <p class="text-sm font-medium">高端市场与出海盲区</p>
                <p class="text-xs text-slate-500">聚焦中低端标准化场景，高端精品民宿、东南亚出海几乎空白</p>
              </div>
            </div>
          </div>
        </div>
