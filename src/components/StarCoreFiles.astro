<div class="grid grid-cols-2 md:grid-cols-4 gap-3">
  {coreFiles.map((file, i) => (
    <div 
      class={`group relative p-4 rounded-lg border bg-ai-bg/40 cursor-pointer transition-all duration-200 hover:bg-ai-bg/70 ${colorMap[file.color]}`}
      data-core-file={file.id}
      data-core-color={file.color}
    >
      {/* Header */}
      <div class="flex items-center gap-2 mb-2">
        <span class={`w-1.5 h-1.5 rounded-full ${dotMap[file.color]}`}></span>
        <span class="font-mono text-[10px] opacity-50 tracking-wider">{file.label}</span>
      </div>
      
      {/* Title */}
      <h3 class="font-star text-sm tracking-wide mb-1.5 text-ai-text/90">{file.title}</h3>
      
      {/* Preview — single line */}
      <p class="text-xs text-ai-text/40 leading-relaxed line-clamp-2 mb-2">
        {file.content.split('\n')[0]}
      </p>
      
      {/* File size hint */}
      <div class="flex items-center justify-between">
        <span class="font-mono text-[9px] text-gray-light/30">{String(file.content.length)} bytes</span>
        <span class="font-mono text-[9px] text-gray-light/30 opacity-0 group-hover:opacity-100 transition-opacity">[OPEN]</span>
      </div>
    </div>
  ))}
</div>

{/* Detail modal — Terminal Editor Style */}
<div id="core-modal" class="fixed inset-0 z-[100] hidden">
  {/* Backdrop with scanlines */}
  <div class="absolute inset-0 bg-ai-bg/90 backdrop-blur-sm" data-close-modal></div>
  <div class="absolute inset-0 pointer-events-none opacity-[0.03]" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(255,255,255,0.1) 2px, rgba(255,255,255,0.1) 4px);"></div>
  
  {/* Terminal window */}
  <div 
    id="core-modal-window" 
    class={`absolute inset-x-3 top-[5%] md:inset-x-auto md:left-1/2 md:-translate-x-1/2 md:w-[720px] max-h-[90vh] flex flex-col rounded-lg border border-gray-deep/30 bg-[#0a0e1a] overflow-hidden opacity-0 scale-[0.96] translate-y-2 transition-all duration-400 ease-[cubic-bezier(0.16,1,0.3,1)]`}
  >
    {/* Top accent glow line */}
    <div id="modal-accent" class="h-[2px] w-full"></div>
    
    {/* Title bar — macOS terminal style */}
    <div class="flex items-center gap-3 px-4 py-2.5 border-b border-gray-deep/20 bg-[#0d1220]">
      <div class="flex gap-1.5">
        <span class="w-2.5 h-2.5 rounded-full bg-[#ff5f56] border border-[#e0443e]/30"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-[#ffbd2e] border border-[#dea123]/30"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-[#27c93f] border border-[#1aab29]/30"></span>
      </div>
      <span id="modal-label" class="font-mono text-[10px] text-gray-light/30 tracking-widest flex-1 text-center"></span>
      <button data-close-modal class="text-gray-light/20 hover:text-gray-light/60 transition-colors p-0.5">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    
    {/* Content area with line numbers */}
    <div class="flex-1 overflow-y-auto custom-scrollbar">
      <div class="flex min-h-full">
        {/* Line numbers gutter */}
        <div 
          id="modal-linenumbers" 
          class="font-mono text-[11px] text-gray-light/15 bg-[#070a14] border-r border-gray-deep/10 py-5 px-3 text-right select-none leading-[1.875] w-12 shrink-0"
        ></div>
        
        {/* Main content */}
        <div class="flex-1 py-5 px-5 min-w-0">
          <h3 id="modal-title" class="font-star text-lg tracking-wide mb-1 text-ai-text/90"></h3>
          <p id="modal-meta" class="font-mono text-[10px] text-gray-light/20 mb-5 tracking-wider"></p>
          
          <div id="modal-content" class="font-mono text-[13px] text-ai-text/75 leading-[1.875] whitespace-pre-wrap"></div>
          
          {/* Blinking cursor */}
          <span class="inline-block w-[7px] h-[18px] bg-aurora-blue/70 ml-0.5 mt-1 animate-pulse align-text-bottom"></span>
        </div>
      </div>
    </div>
    
    {/* Status bar */}
    <div class="flex items-center justify-between px-4 py-1.5 border-t border-gray-deep/20 bg-[#0d1220]">
      <div class="flex items-center gap-3">
        <span class="font-mono text-[9px] text-gray-light/25">UTF-8</span>
        <span class="font-mono text-[9px] text-gray-light/25" id="modal-filesize"></span>
      </div>
      <div class="flex items-center gap-2">
        <span class="w-1 h-1 rounded-full bg-aurora-green/50 animate-pulse"></span>
        <span class="font-mono text-[9px] text-gray-light/25">READ-ONLY</span>
      </div>
    </div>
  </div>
</div>

<style>
  .duration-400 { transition-duration: 400ms; }
  .custom-scrollbar::-webkit-scrollbar { width: 6px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(100,116,139,0.15); border-radius: 3px; }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(100,116,139,0.3); }
</style>

