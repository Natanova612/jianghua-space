---
import BaseLayout from './BaseLayout.astro';
import DualHeader from '../components/DualHeader.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage} field="human">
  <div class="min-h-screen flex flex-col bg-human-bg text-human-text">
    <DualHeader currentField="human" />
    <main class="flex-1">
      <slot />
    </main>
    <Footer field="human" />
  </div>
</BaseLayout>
